        BackgroundColor3 = T.Accent, BorderSizePixel = 0,
    })
    Corner(fill, 4)
    Gradient(fill, {"Accent3", "Accent", "Accent2"}, 0)
    local knob = New("Frame", {
        Parent = fill, AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.fromScale(1, 0.5),
