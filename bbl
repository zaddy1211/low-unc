					end
				end
				if closest then hrp.CFrame = CFrame.new(closest.Position + closest.CFrame.LookVector * BLS.reboundOffset) end
			end
		end
		if BLS.ballHitboxOn then
			updateBallHitbox()
			local ch = getChar(); if ch and ch:FindFirstChild("HumanoidRootPart") then
				local hrp = ch.HumanoidRootPart
				for _, v in BL_Workspace:GetDescendants() do
					if v.Name == "Basketball" and v:IsA("BasePart") then
						local dist = (hrp.Position - v.Position).Magnitude
						if dist < (BLS.ballHitSize / 2) and dist > 3 then
							v.Velocity = v.Velocity:Lerp((hrp.Position - v.Position).Unit * 44 * (1 + (BLS.ballHitSize/2 - dist)/6) * 26, 0.65)
						end
					end
				end
			end
		end
		if BLS.stealReachOn then local ch = getChar(); if ch then resizeStealArms(ch) end end
		if BLS.postHold and BLS.postOn then executePostAimbot() end
	end))

	bl_track(BL_UIS.InputBegan:Connect(function(input, gp)
		if gp or BL_UIS:GetFocusedTextBox() then return end
		if input.KeyCode == Enum.KeyCode.G and BLS.autoGuardToggle then
			BLS.autoGuardHold = true; BLS.lastBallPos = {}; BLS.lastBallTime = {}
			if not BLS.autoGuardConn then BLS.autoGuardConn = BL_RunService.Heartbeat:Connect(autoGuardStep); bl_track(BLS.autoGuardConn) end
		end
		if input.KeyCode == Enum.KeyCode.P and BLS.postOn then BLS.postHold = true end
		if input.KeyCode == Enum.KeyCode.M then BLS.magnetOn = not BLS.magnetOn end
		-- H key follow removed
		if input.KeyCode == Enum.KeyCode.R and BLS.rTpOn and BLS.canRTp then
			local ch = getChar(); if ch and ch:FindFirstChild("HumanoidRootPart") then
				local hum = ch:FindFirstChildOfClass("Humanoid"); local hrp = ch.HumanoidRootPart
				local dir = hum and hum.MoveDirection.Magnitude > 0 and hum.MoveDirection.Unit or hrp.CFrame.LookVector
				hrp.CFrame = hrp.CFrame + dir * BLS.rTpDist; BLS.canRTp = false
				task.delay(BLS.rTpDelay, function() BLS.canRTp = true end)
			end
		end
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			task.spawn(performUnblockable)
		end
	end))

	bl_track(BL_UIS.InputEnded:Connect(function(input)
		if input.KeyCode == Enum.KeyCode.G then
			BLS.autoGuardHold = false
			if BLS.autoGuardConn then BLS.autoGuardConn:Disconnect(); BLS.autoGuardConn = nil end
			BLS.lastBallPos = {}; BLS.lastBallTime = {}
			game:GetService("VirtualInputManager"):SendKeyEvent(false, Enum.KeyCode.F, false, game)
		end
		if input.KeyCode == Enum.KeyCode.P then BLS.postHold = false end
	end))

	bl_track(BL_LocalPlayer.CharacterAdded:Connect(function(char)
		task.wait(0.5)
		local hum = char:WaitForChild("Humanoid", 10)
		if hum then BLS.baseJump = hum.UseJumpPower and hum.JumpPower or (hum.JumpHeight * 10); applyJump() end
		resizeStealArms(char); applyHipHeight(); BLS.lastDodgeTime = 0; BLS.lastScanTime = 0
		char.DescendantAdded:Connect(function(desc)
			if table.find(armNames, desc.Name) then task.wait(0.05); resizeStealArms(char) end
		end)
	end))

	for _, plr in BL_Players:GetPlayers() do attachEsp(plr) end
	bl_track(BL_Players.PlayerAdded:Connect(function(plr) attachEsp(plr) end))
	bl_track(BL_Players.PlayerRemoving:Connect(function(plr) clearEsp(plr) end))
end

