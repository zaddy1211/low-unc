local function getChar() return BL_LocalPlayer.Character end
local function getHum() local ch = getChar(); return ch and ch:FindFirstChildOfClass("Humanoid"), ch end

local function bl_isPark()
	local g = BL_Workspace:FindFirstChild("Game")
	return g and g:FindFirstChild("Courts") ~= nil
end
local isParkWorld = bl_isPark()

local function getPlayerFromModel(model)
	for _, plr in BL_Players:GetPlayers() do if plr.Character == model then return plr end end
end

local function isEnemyTeam(otherModel)
	local op = getPlayerFromModel(otherModel)
	if not op then return otherModel ~= getChar() end
	if not BL_LocalPlayer.Team or not op.Team then return op ~= BL_LocalPlayer end
	return BL_LocalPlayer.Team ~= op.Team
end

local function playerHasBall()
	local ch = getChar(); if not ch then return false end
	local t = ch:FindFirstChild("Basketball"); return t and t:IsA("Tool")
end

local function findPlayerWithBall()
	local myCh = getChar()
	if not myCh or not myCh:FindFirstChild("HumanoidRootPart") then return nil, nil end
	local myRoot = myCh.HumanoidRootPart
	if isParkWorld then
		local closest, closestDist = nil, math.huge
		for _, model in BL_Workspace:GetChildren() do
			if model:IsA("Model") and model:FindFirstChild("HumanoidRootPart") and model ~= myCh then
				local tool = model:FindFirstChild("Basketball")
				if tool and tool:IsA("Tool") then
					local d = (model.HumanoidRootPart.Position - myRoot.Position).Magnitude
					if d < closestDist then closestDist = d; closest = model end
				end
			end
		end
		if closest then return closest, closest:FindFirstChild("HumanoidRootPart") end
		return nil, nil
	end
	local loose = BL_Workspace:FindFirstChild("Basketball")
	if loose and loose:IsA("BasePart") then
		local closest, closestDist = nil, math.huge
		for _, model in BL_Workspace:GetChildren() do
			if model:IsA("Model") and model:FindFirstChild("HumanoidRootPart") and model ~= myCh then
				if isEnemyTeam(model) then
					local d = (loose.Position - model.HumanoidRootPart.Position).Magnitude
					if d < closestDist and d < 15 then closestDist = d; closest = model end
				end
			end
		end
		if closest then return closest, closest:FindFirstChild("HumanoidRootPart") end
	end
	for _, model in BL_Workspace:GetChildren() do
		if model:IsA("Model") and model:FindFirstChild("HumanoidRootPart") and model ~= myCh then
			if isEnemyTeam(model) then
				local ball = model:FindFirstChild("Basketball")
				if ball and ball:IsA("Tool") then return model, model.HumanoidRootPart end
			end
		end
	end
	return nil, nil
end

local function getClosestOpponentRoot()
	local ch = getChar(); if not ch or not ch:FindFirstChild("HumanoidRootPart") then return nil end
	local myRoot = ch.HumanoidRootPart; local closest, minD = nil, BLS.postDist
	for _, plr in BL_Players:GetPlayers() do
		if plr ~= BL_LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
			if isEnemyTeam(plr.Character) then
				local er = plr.Character.HumanoidRootPart; local d = (er.Position - myRoot.Position).Magnitude
				if d < minD then minD = d; closest = er end
			end
		end
	end
	return closest
end

local function detectBallHand()
	local ch = getChar(); if not ch then return "right" end
	local tool = ch:FindFirstChild("Basketball")
	if tool and tool:IsA("Tool") then
		local h = tool:FindFirstChild("Handle"); local root = ch:FindFirstChild("HumanoidRootPart")
		if h and root then return root.CFrame:ToObjectSpace(h.CFrame).X > 0 and "right" or "left" end
	end
	return "right"
end

