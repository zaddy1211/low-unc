local function getDodgeDirection()
	local ch = getChar(); if not ch then return nil end
	local hrp = ch:FindFirstChild("HumanoidRootPart"); local hum = ch:FindFirstChildOfClass("Humanoid")
	if not hrp then return nil end
	local md = hum and hum.MoveDirection or Vector3.zero
	return md.Magnitude > 0.1 and md.Unit or hrp.CFrame.LookVector
end

-- ── RUNTIME LOOPS ────────────────────────────────────────────────────────────

local function setupBLRuntime()
	bl_track(BL_RunService.Heartbeat:Connect(function()
		if BLS.magnetOn then
			local ch = getChar(); if ch and ch:FindFirstChild("HumanoidRootPart") then
				local hrp = ch.HumanoidRootPart; local closest, closestDist = nil, BLS.magDist
				for _, v in BL_Workspace:GetDescendants() do
					if v.Name == "Basketball" and v:IsA("BasePart") then
						local d = (hrp.Position - v.Position).Magnitude
						if d < closestDist and d > 2.5 then closestDist = d; closest = v end
					end
				end
				if closest then
					local dir = (closest.Position - hrp.Position).Unit
					local pull = dir * (BLS.magStrength * (BLS.magDist - closestDist) / BLS.magDist) * 1.35
					pull += Vector3.new(math.random(-4,4), 0.6, math.random(-4,4)) * 0.15
					closest.Velocity = closest.Velocity:Lerp(pull * 30, 0.42)
				end
				if type(firetouchinterest) == "function" then
					for _, v in BL_Workspace:GetDescendants() do
						if v.Name == "Basketball" and v:IsA("BasePart") then
							if (hrp.Position - v.Position).Magnitude <= math.min(BLS.magDist, 18) then
								if v:FindFirstChildOfClass("TouchTransmitter") then
									pcall(function() firetouchinterest(hrp, v, 0); firetouchinterest(hrp, v, 1) end)
								end
							end
						end
					end
				end
			end
		end
		if BLS.dodgeOn and playerHasBall() then
			local now = tick()
			if now - BLS.lastScanTime >= 0.1 then BLS.lastScanTime = now
				local ch = getChar(); if ch and ch:FindFirstChild("HumanoidRootPart") then
					local myRoot = ch.HumanoidRootPart
					if now - BLS.lastDodgeTime >= 0.5 then
						local closestDist = math.huge
						for _, plr in BL_Players:GetPlayers() do
							if plr ~= BL_LocalPlayer and plr.Character then
								local root = plr.Character:FindFirstChild("HumanoidRootPart")
								if root then local d = (myRoot.Position - root.Position).Magnitude; if d < closestDist then closestDist = d end end
							end
						end
						if closestDist <= BLS.dodgeDist then task.spawn(function()
							task.wait(BLS.dodgeDelay); if not BLS.dodgeOn or not playerHasBall() then return end
							local nr = getChar() and getChar():FindFirstChild("HumanoidRootPart"); if not nr then return end
							local dir = getDodgeDirection(); if dir then nr.CFrame = CFrame.new(nr.Position + dir * 5); BLS.lastDodgeTime = tick() end
						end) end
					end
				end
			end
		end
	end))

	bl_track(BL_RunService.RenderStepped:Connect(function(dt)
		if BLS.reboundOn then
			local ch = getChar(); if ch and ch:FindFirstChild("HumanoidRootPart") then
				local hrp = ch.HumanoidRootPart; local closest, closestDist = nil, math.huge
				for _, child in BL_Workspace:GetChildren() do
					if child.Name == "Basketball" then
						local part = child:IsA("BasePart") and child or child:FindFirstChildWhichIsA("BasePart")
						if part then local d = (part.Position - hrp.Position).Magnitude; if d < closestDist then closestDist = d; closest = part end end
					end
				end
				if closest then hrp.CFrame = CFrame.new(closest.Position + closest.CFrame.LookVector * BLS.reboundOffset) end
			end
		end
		if BLS.ballHitboxOn then
			updateBallHitbox()
			local ch = getChar(); if ch and ch:FindFirstChild("HumanoidRootPart") then
				local hrp = ch.HumanoidRootPart
				for _, v in BL_Workspace:GetDescendants() do
					if v.Name == "Basketball" and v:IsA("BasePart") then
						local dist = (hrp.Position - v.Position).Magnitude
						if dist < (BLS.ballHitSize / 2) and dist > 3 then
							v.Velocity = v.Velocity:Lerp((hrp.Position - v.Position).Unit * 44 * (1 + (BLS.ballHitSize/2 - dist)/6) * 26, 0.65)
						end
					end
				end
			end
		end
		if BLS.stealReachOn then local ch = getChar(); if ch then resizeStealArms(ch) end end
		if BLS.postHold and BLS.postOn then executePostAimbot() end
	end))

	bl_track(BL_UIS.InputBegan:Connect(function(input, gp)
		if gp or BL_UIS:GetFocusedTextBox() then return end
		if input.KeyCode == Enum.KeyCode.G and BLS.autoGuardToggle then
			BLS.autoGuardHold = true; BLS.lastBallPos = {}; BLS.lastBallTime = {}
			if not BLS.autoGuardConn then BLS.autoGuardConn = BL_RunService.Heartbeat:Connect(autoGuardStep); bl_track(BLS.autoGuardConn) end
		end
		if input.KeyCode == Enum.KeyCode.P and BLS.postOn then BLS.postHold = true end
		if input.KeyCode == Enum.KeyCode.M then BLS.magnetOn = not BLS.magnetOn end
		-- H key follow removed
		if input.KeyCode == Enum.KeyCode.R and BLS.rTpOn and BLS.canRTp then
			local ch = getChar(); if ch and ch:FindFirstChild("HumanoidRootPart") then
				local hum = ch:FindFirstChildOfClass("Humanoid"); local hrp = ch.HumanoidRootPart
				local dir = hum and hum.MoveDirection.Magnitude > 0 and hum.MoveDirection.Unit or hrp.CFrame.LookVector
				hrp.CFrame = hrp.CFrame + dir * BLS.rTpDist; BLS.canRTp = false
				task.delay(BLS.rTpDelay, function() BLS.canRTp = true end)
			end
		end
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			task.spawn(performUnblockable)
