local function bindAutoRelease()
	if BLS.shootConn then BLS.shootConn:Disconnect(); BLS.shootConn = nil end
	if not BLS.autoRelease then return end
	local shootEl = getShootingElement(); local shootRm = getShootRemote()
	if not (shootEl and shootRm) then return end
	BLS.shootConn = shootEl:GetPropertyChangedSignal("Visible"):Connect(function()
		if BLS.autoRelease and shootEl.Visible then
			task.wait(0.24); pcall(function() shootRm:FireServer(BLS.shootPower) end)
		end
	end)
end

local function performUnblockable()
	if not BLS.unblockableOn or BLS.unblockInProg then return end
	local now = tick(); if now - BLS.lastUnblockTime < 0.3 then return end
	local ch = getChar(); if not ch then return end
	local hrp = ch:FindFirstChild("HumanoidRootPart"); if not hrp or not playerHasBall() then return end
	BLS.unblockInProg = true; local origY = hrp.Position.Y
	hrp.CFrame = hrp.CFrame + Vector3.new(0, 9, 0); BLS.lastUnblockTime = now
	task.spawn(function()
		task.wait(0.39)
		if hrp and hrp.Parent then hrp.CFrame = CFrame.new(hrp.Position.X, origY, hrp.Position.Z) end
		BLS.unblockInProg = false
	end)
end

local function updateBallHitbox()
	if not BLS.ballHitboxOn then
		for _, v in BL_Workspace:GetDescendants() do
			if v.Name == "Basketball" and v:IsA("BasePart") then v.Size = Vector3.new(1.5,1.5,1.5); v.CustomPhysicalProperties = nil end
		end
		for ball, vis in pairs(BLS.hitboxVisuals) do if vis and vis.Parent then vis:Destroy() end; BLS.hitboxVisuals[ball] = nil end
		return
	end
	for ball, vis in pairs(BLS.hitboxVisuals) do
		if not ball or not ball.Parent or ball.Name ~= "Basketball" then if vis and vis.Parent then vis:Destroy() end; BLS.hitboxVisuals[ball] = nil end
	end
	for _, v in BL_Workspace:GetDescendants() do
		if v.Name == "Basketball" and v:IsA("BasePart") then
			v.Size = Vector3.new(BLS.ballHitSize, BLS.ballHitSize, BLS.ballHitSize)
			v.CustomPhysicalProperties = PhysicalProperties.new(0.7, 0.3, 0.5); v.CanCollide = true; v.Anchored = false
			local visual = BLS.hitboxVisuals[v]
			if not visual or not visual.Parent then
				visual = Instance.new("Part"); visual.Name = "LyraBallHitboxVisual"; visual.Shape = Enum.PartType.Ball
				visual.Transparency = 0.68; visual.Color = Color3.fromRGB(132,98,255); visual.Material = Enum.Material.ForceField
				visual.CanCollide = false; visual.Anchored = true; visual.Parent = BL_Workspace; BLS.hitboxVisuals[v] = visual
			end
			visual.Size = Vector3.new(BLS.ballHitSize, BLS.ballHitSize, BLS.ballHitSize); visual.Position = v.Position
		end
	end
end

local function resizeStealArms(character)
	if not character then return end
	for _, name in ipairs(armNames) do
		local arm = character:FindFirstChild(name)
		if arm and arm:IsA("BasePart") then
			if not BLS.origArmSize[name] then BLS.origArmSize[name] = arm.Size; BLS.origArmTrans[name] = arm.Transparency end
			if BLS.stealReachOn then
				arm.Size = BLS.origArmSize[name] * BLS.stealMult; arm.Transparency = 1; arm.CanCollide = false; arm.Massless = true
			else
				arm.Size = BLS.origArmSize[name]; arm.Transparency = BLS.origArmTrans[name]; arm.Massless = false
			end
		end
	end
end

local function startSpeed()
	if BLS.speedStop then BLS.speedStop(); BLS.speedStop = nil end
	local conn; conn = BL_RunService.RenderStepped:Connect(function(dt)
		local ch = getChar(); if not ch then return end
		local root = ch:FindFirstChild("HumanoidRootPart"); local hum = ch:FindFirstChildOfClass("Humanoid")
		if not root or not hum then return end
		local moveVec = hum.MoveDirection
		if moveVec.Magnitude > 0 then root.CFrame = root.CFrame + (moveVec.Unit * math.max(BLS.speedTarget - hum.WalkSpeed, 0) * dt) end
	end)
	BLS.speedStop = function() if conn then conn:Disconnect() end end
end

local function applyJump()
	local hum = select(1, getHum()); if not hum then return end
	if BLS.jumpOn then
		if hum.UseJumpPower then hum.JumpPower = BLS.jumpPower else hum.JumpHeight = BLS.jumpPower / 10 end
	else
		if hum.UseJumpPower then hum.JumpPower = BLS.baseJump else hum.JumpHeight = BLS.baseJump / 10 end
	end
end

local function applyHipHeight()
	local ch = getChar(); if not ch then return end
	local hum = ch:FindFirstChild("Humanoid"); if not hum then return end
	hum.HipHeight = BLS.hipHeightOn and BLS.hipHeightVal or 2
end

local function autoGuardStep()
	if not BLS.autoGuardHold or playerHasBall() then return end
	local ch = getChar(); if not ch then return end
	local hum = ch:FindFirstChildOfClass("Humanoid"); local root = ch:FindFirstChild("HumanoidRootPart")
	if not hum or not root then return end
	local carrier, cRoot = findPlayerWithBall()
	if carrier and cRoot then
		local dist = (root.Position - cRoot.Position).Magnitude
		local now = tick(); local lastP = BLS.lastBallPos[carrier]; local lastT = BLS.lastBallTime[carrier] or now
		local dt = math.max(now - lastT, 1/120)
		local vel = lastP and ((cRoot.Position - lastP) / dt) or Vector3.zero
		BLS.lastBallPos[carrier] = cRoot.Position; BLS.lastBallTime[carrier] = now
		local predicted = cRoot.Position + (vel * BLS.predictT * 60)
		local dir = (predicted - root.Position).Unit
		local defPos = Vector3.new((predicted - dir * 5).X, root.Position.Y, (predicted - dir * 5).Z)
		local VIM = game:GetService("VirtualInputManager")
		if dist <= BLS.guardDist then
			hum:MoveTo(defPos)
			if dist <= 10 then VIM:SendKeyEvent(true, Enum.KeyCode.F, false, game) else VIM:SendKeyEvent(false, Enum.KeyCode.F, false, game) end
		else VIM:SendKeyEvent(false, Enum.KeyCode.F, false, game) end
	else game:GetService("VirtualInputManager"):SendKeyEvent(false, Enum.KeyCode.F, false, game) end
end

local function executePostAimbot()
	if not BLS.postHold then return end
	local ch = getChar(); if not ch or not ch:FindFirstChild("HumanoidRootPart") then return end
	local myRoot = ch.HumanoidRootPart; local target = getClosestOpponentRoot()
	if target then
		local dir = (target.Position - myRoot.Position).Unit
		local face = CFrame.new(myRoot.Position, myRoot.Position + dir)
		if playerHasBall() then
			local hand = detectBallHand(); myRoot.CFrame = face * CFrame.Angles(0, math.rad(hand == "left" and 90 or -90), 0)
		else myRoot.CFrame = face end
	end
end

local function clearEsp(plr) local h = BLS.espHighlights[plr]; if h then pcall(function() h:Destroy() end) end; BLS.espHighlights[plr] = nil end
local function attachEsp(plr)
	if plr == BL_LocalPlayer or not BLS.espOn then return end; clearEsp(plr)
	local function onChar(char)
		if not char then return end
		task.defer(function()
			if not BLS.espOn then return end
			local hi = Instance.new("Highlight"); hi.Name = "LyraESP"
			hi.FillColor = Color3.fromRGB(220,80,80); hi.OutlineColor = Color3.fromRGB(255,255,255)
			hi.FillTransparency = 0.55; hi.OutlineTransparency = 0.2; hi.Parent = char; BLS.espHighlights[plr] = hi
		end)
	end
	plr.CharacterAdded:Connect(onChar); if plr.Character then onChar(plr.Character) end
end
local function refreshEspAll()
	for _, plr in BL_Players:GetPlayers() do clearEsp(plr); if BLS.espOn then attachEsp(plr) end end
end

local function enableAntiLag()
	BLS.origLighting.global = BL_Lighting.GlobalShadows; BLS.origLighting.quality = settings().Rendering.QualityLevel
	BL_Lighting.GlobalShadows = false; BL_Lighting.Brightness = 1; BL_Lighting.ClockTime = 12; BL_Lighting.FogEnd = 100000
	settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
	for _, v in BL_Workspace:GetDescendants() do if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") then v.Enabled = false end end
	pcall(function() BL_Workspace.Terrain.WaterWaveSize = 0; BL_Workspace.Terrain.WaterReflectance = 0; BL_Workspace.Terrain.WaterTransparency = 1 end)
end
local function disableAntiLag()
	BL_Lighting.GlobalShadows = BLS.origLighting.global ~= false
	if BLS.origLighting.quality ~= nil then settings().Rendering.QualityLevel = BLS.origLighting.quality end
end

local function unlockAllItems()
	local ok, knit = pcall(function() return require(BL_RS.Packages.Knit) end)
	if not ok or not knit then return false, "Knit not found" end
	local ok2, items = pcall(function() return require(BL_RS.Modules.Items) end)
	if not ok2 or not items then return false, "Items module not found" end
	local ok3, dc = pcall(function() return knit.GetController("DataController") end)
	if not ok3 or not dc or not dc.Data then return false, "DataController missing" end
	local data = dc.Data; local inv = { Skins = {}, Effects = {}, Banners = {}, Emotes = {} }
	for cat, _ in pairs(inv) do if items[cat] then for name, _ in pairs(items[cat]) do table.insert(inv[cat], {name, false}) end end end
	if items.Dunks and data.Dunks and data.Dunks.Owned then for n, _ in pairs(items.Dunks) do data.Dunks.Owned[n] = true end end
	if data.Gamepasses then for n, _ in pairs(data.Gamepasses) do data.Gamepasses[n] = true end end
	if type(data.Prestige) == "number" then data.Prestige = 3 end
	data.Inventory = inv; return true
end

local function setFollow(on)
	BLS.followOn = on
	if BLS.followConn then BLS.followConn:Disconnect(); BLS.followConn = nil end
	if on then
		BLS.followConn = BL_RunService.Heartbeat:Connect(function()
			if not BLS.followOn then return end
			local ch = getChar(); if not ch or not ch:FindFirstChild("HumanoidRootPart") then return end
			local _, bcRoot = findPlayerWithBall()
			if bcRoot then ch.HumanoidRootPart.CFrame = bcRoot.CFrame * CFrame.new(0, 0, BLS.followZ) end
		end)
		bl_track(BLS.followConn)
	end
end

