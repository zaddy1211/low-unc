    local ScalesToUpdate = {MainScale}

    local WindowObj = { Tabs = {}, CurrentTab = nil, ElementsList = {} }
    
    local MenuVisible = true
    local MobileHideButton = nil
    local MobileHideLabel = nil
    local MobileHideButtonEnabled = true
    
