local function getShootRemote()
	local ok, r = pcall(function()
		local p = BL_RS:WaitForChild("Packages", 8)
		local knit = p and p:WaitForChild("Knit", 5)
		local svc = knit and knit:WaitForChild("Services", 5)
		local ctrl = svc and svc:WaitForChild("ControlService", 5)
		local re = ctrl and ctrl:FindFirstChild("RE")
		return re and re:FindFirstChild("Shoot")
	end)
	return ok and r and r:IsA("RemoteEvent") and r or nil
end

local function getShootingElement()
	local vis = BL_PlayerGui:FindFirstChild("Visual")
	return vis and vis:FindFirstChild("Shooting")
end

