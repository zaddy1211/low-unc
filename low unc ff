            Element.Value = v
            if cb then task.spawn(function() pcall(cb, v) end) end
        end)
        ConfigManager.Register(tabName .. "/" .. name, control)
        function Element:Set(val)
            Element.Value = val
            control.Set(val, false)
            if cb then task.spawn(function() pcall(cb, val) end) end
        end
        function Element:Refresh(newOpts)
            if control.Refresh then control.Refresh(newOpts) end
        end
        return Element
    end

    function Tab:CreateButton(options)
        options = options or {}
        local name = options.Name or "Button"
        local cb = options.Callback or function() end
        Button(page, currentCard, name, false, function()
            task.spawn(function() pcall(cb) end)
        end)
    end

    function Tab:CreateTextbox(options)
        options = options or {}
        local name = options.Name or "Textbox"
        local default = options.Default or ""
        local cb = options.Callback
        local Element = { Value = default }
        local control = Textbox(page, currentCard, name, "Type...", default, function(txt)
            Element.Value = txt
            if cb then task.spawn(function() pcall(cb, txt) end) end
        end)
        ConfigManager.Register(tabName .. "/" .. name, control)
        function Element:Set(val)
            Element.Value = val
            control.Set(val, false)
            if cb then task.spawn(function() pcall(cb, val) end) end
        end
        return Element
    end

    function Tab:CreateKeybind(options)
        options = options or {}
        local name = options.Name or "Keybind"
        local default = options.Default or Enum.KeyCode.E
        local cb = options.Callback
        local Element = { Value = default }
        local control = Keybind(page, currentCard, name, default, function(key)
            Element.Value = key
            if cb then task.spawn(function() pcall(cb, key) end) end
        end)
        ConfigManager.Register(tabName .. "/" .. name, control)
        function Element:Set(val)
            Element.Value = val
            control.Set(val, false)
            if cb then task.spawn(function() pcall(cb, val) end) end
        end
        return Element
    end

    function Tab:CreateColorpicker(options)
        options = options or {}
        local name = options.Name or "Colorpicker"
        local default = options.Default or Color3.fromRGB(255, 255, 255)
        local cb = options.Callback
        local Element = { Value = default }
        local control = Colorpicker(page, currentCard, name, default, function(c)
