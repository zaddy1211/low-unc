local function LoadDefenseTab()
    local DefenseTab = Window:CreateTab({ 
        Name = 'Defense', 
        Icon = 'rbxassetid://14939023862' 
    })

    -- ═══════════════════════════════════════════════════════════════
    -- STATE & CONFIG MANAGER
    -- ═══════════════════════════════════════════════════════════════
    local State = {
        swatReach = false,
        tackleReach = false,
        tackleAimbot = false,
        blockReach = false,
        showBlockHitbox = false,
        blockQBCheck = false,
        blockLookAtTarget = false,
    }

    local Config = {
        swatReachDistance = 0,
        tackleAimbotRange = 0,
        tackleAimbotType = 'Teleport',
        tackleGlidePower = 1,
        blockLateralReach = 1,
        blockLongReach = 1,
        blockMultiplier = 1,
    }

    -- ═══════════════════════════════════════════════════════════════
    -- UTILITY — TARGET FINDER
    -- ═══════════════════════════════════════════════════════════════
    local TargetFinder = {}

    function TargetFinder.GetBallCarriers(excludeSelf)
        local carriers = {}
        for _, v in next, players:GetPlayers() do
            if excludeSelf and v == player then continue end
            if v.Team == player.Team then continue end
            if not v.Character then continue end
            if not v.Character:FindFirstChild('Football') then continue end
            table.insert(carriers, v)
        end
        return carriers
    end

    function TargetFinder.GetEnemyPlayers(excludeSelf, requireHRP)
        local enemies = {}
        for _, v in next, players:GetPlayers() do
            if excludeSelf and v == player then continue end
            if v.Team == player.Team then continue end
            if not v.Character then continue end
            if requireHRP and not v.Character:FindFirstChild('HumanoidRootPart') then continue end
            table.insert(enemies, v)
        end
        return enemies
    end

    function TargetFinder.GetNearestEnemy(position, filter)
        local nearest, nearestDist = nil, math.huge
        for _, v in next, players:GetPlayers() do
            if v == player then continue end
            if v.Team == player.Team then continue end
            if not v.Character then continue end
            local hrp = v.Character:FindFirstChild('HumanoidRootPart')
            if not hrp then continue end
            if filter and not filter(v) then continue end
            
            local dist = (hrp.Position - position).Magnitude
            if dist < nearestDist then
                nearestDist = dist
                nearest = v
            end
        end
        return nearest, nearestDist
    end

    -- ═══════════════════════════════════════════════════════════════
    -- SWAT ENGINE — EXTENDED REACH
    -- ═══════════════════════════════════════════════════════════════
    task.spawn(function()
        while true do
            task.wait()

            if not State.swatReach then continue end

            local character = player.Character
            if not character then continue end

            local ball = findClosestBall()
            if not ball then continue end

            for _, v in next, character:GetChildren() do
                if not v:IsA('BasePart') then continue end
                if not v.Name:lower():find('catch') then continue end

                local distance = (ball.Position - v.Position).Magnitude
                if distance < Config.swatReachDistance and v.Size.X > 2 then
                    pcall(function()
                        firetouchinterest(v, ball, 0)
                        firetouchinterest(v, ball, 1)
                    end)
                end
            end
        end
    end)

    -- ═══════════════════════════════════════════════════════════════
    -- TACKLE ENGINE — REACH + AIMBOT
    -- ═══════════════════════════════════════════════════════════════
    local TackleEngine = {
        bodyParts = {'Torso', 'Head', 'HumanoidRootPart', 'Left Arm', 'Left Leg', 'Right Arm', 'Right Leg'},
    }

    function TackleEngine.FireTackleRemotes()
        for _, carrier in next, TargetFinder.GetBallCarriers(true) do
            local randomPart = self.bodyParts[math.random(1, #self.bodyParts)]
            pcall(function()
                replicatedStorage.Remotes.CharacterSoundEvent:FireServer(
                    'Game', 
                    'TackleTouch', 
                    randomPart, 
                    randomPart
                )
            end)
        end
    end

    function TackleEngine.TeleportToCarrier(carrier, myHRP)
        if not carrier.Character then return end
        local carrierHRP = carrier.Character:FindFirstChild('HumanoidRootPart')
        if not carrierHRP then return end
        myHRP.CFrame = carrierHRP.CFrame
    end

    function TackleEngine.GlideToCarrier(carrier, myHRP, power)
        if not carrier.Character then return end
        local carrierHRP = carrier.Character:FindFirstChild('HumanoidRootPart')
        if not carrierHRP then return end
        
        local direction = (carrierHRP.Position - myHRP.Position).Unit
        myHRP.AssemblyLinearVelocity = direction * (power * 50)
    end

    task.spawn(function()
        while true do
            task.wait()

            local character = player.Character
            if not character then continue end

            local myHRP = character:FindFirstChild('HumanoidRootPart')
            if not myHRP then continue end

            -- Tackle Reach — fire remotes at all carriers
            if State.tackleReach then
                TackleEngine.FireTackleRemotes()
            end

            -- Tackle Aimbot — move to nearest carrier
            if State.tackleAimbot then
                local nearestCarrier, dist = TargetFinder.GetNearestEnemy(
                    myHRP.Position,
                    function(v) 
                        return v.Character 
                            and v.Character:FindFirstChild('Humanoid') 
                            and v.Character.Humanoid.WalkSpeed > 0
                            and v.Character:FindFirstChild('Football')
                    end
                )

                if nearestCarrier and dist < Config.tackleAimbotRange then
                    if Config.tackleAimbotType == 'Teleport' then
                        TackleEngine.TeleportToCarrier(nearestCarrier, myHRP)
                    elseif Config.tackleAimbotType == 'Glide' then
                        TackleEngine.GlideToCarrier(nearestCarrier, myHRP, Config.tackleGlidePower)
                    end
                end
            end
        end
    end)

    -- ═══════════════════════════════════════════════════════════════
    -- BLOCK ENGINE — LATERAL/LONGITUDINAL REACH
    -- ═══════════════════════════════════════════════════════════════
    local BlockEngine = {
        visual = nil,
    }

    BlockEngine.visual = Instance.new('Part')
    BlockEngine.visual.Name = 'FF3_BlockRadiusVisual'
    BlockEngine.visual.Anchored = true
    BlockEngine.visual.CanCollide = false
    BlockEngine.visual.CanTouch = false
    BlockEngine.visual.CanQuery = false
    BlockEngine.visual.CastShadow = false
    BlockEngine.visual.Shape = Enum.PartType.Ball
    BlockEngine.visual.Material = Enum.Material.Neon
    BlockEngine.visual.Color = Theme.Accent
    BlockEngine.visual.Transparency = 0.75

    RegisterVisualTheme(BlockEngine.visual, function()
        BlockEngine.visual.Color = Theme.Accent
    end)

    function BlockEngine.IsInRange(myRoot, targetRoot, lateral, longitudinal)
        local rel = myRoot.CFrame:PointToObjectSpace(targetRoot.Position)
        return math.abs(rel.X) <= lateral and math.abs(rel.Z) <= longitudinal
    end

    function BlockEngine.FireBlockRemotes(count)
        for i = 1, math.max(1, math.floor(count)) do
            pcall(function()
                replicatedStorage.Remotes.CharacterSoundEvent:FireServer('Game', 'Block')
            end)
        end
    end

    function BlockEngine.UpdateVisual(myRoot, lateral, longitudinal)
        BlockEngine.visual.Size = Vector3.new(lateral * 2, 5, longitudinal * 2)
        BlockEngine.visual.CFrame = myRoot.CFrame
        BlockEngine.visual.Parent = workspace.Terrain
    end

    function BlockEngine.HideVisual()
        BlockEngine.visual.Parent = nil
    end

    task.spawn(function()
        while true do
            task.wait()

            local character = player.Character
            if not character then continue end

            local myRoot = character:FindFirstChild('HumanoidRootPart')
            if not myRoot then continue end

            -- Visual update
            if State.blockReach and State.showBlockHitbox then
                BlockEngine.UpdateVisual(myRoot, Config.blockLateralReach, Config.blockLongReach)
            else
                BlockEngine.HideVisual()
            end

            if not State.blockReach then continue end

            -- Block logic
            for _, enemy in next, TargetFinder.GetEnemyPlayers(true, true) do
                if State.blockQBCheck and enemy.Character:FindFirstChild('Football') then continue end
                
                local enemyRoot = enemy.Character:FindFirstChild('HumanoidRootPart')
                if not enemyRoot then continue end

                if BlockEngine.IsInRange(myRoot, enemyRoot, Config.blockLateralReach, Config.blockLongReach) then
                    if State.blockLookAtTarget then
                        myRoot.CFrame = CFrame.lookAt(
                            myRoot.Position, 
                            Vector3.new(enemyRoot.Position.X, myRoot.Position.Y, enemyRoot.Position.Z)
                        )
                    end
                    BlockEngine.FireBlockRemotes(Config.blockMultiplier)
                end
            end
        end
    end)

    -- ═══════════════════════════════════════════════════════════════
    -- UI BINDINGS
    -- ═══════════════════════════════════════════════════════════════
    swatReach = DefenseTab:CreateToggle({
