    -- AUTO CATCH / SWAT / REFLEX — COMBAT ENGINE
    -- ═══════════════════════════════════════════════════════════════
    local ReflexEngine = {
        lastJump = 0,
        cooldown = 3,
    }

    task.spawn(function()
        while true do
            task.wait()

            local anyActive = State.autoCatch.Value or State.autoSwat.Value or State.autoReflexJump.Value
            if not anyActive then continue end

            local character = player.Character
            if not character then continue end

            local humanoid = character:FindFirstChildOfClass("Humanoid")
            if not humanoid then continue end

            local catchZones = BallFinder.GetCatchZones(character)
            if #catchZones == 0 then continue end

            local ball = nil
            pcall(function() ball = BallFinder.GetClosestBall(character:GetPivot().Position) end)
            if not ball or not ball.Parent then continue end

            if State.reflexGroundCheck.Value and ball.Position.Y < 4 then
                continue
            end

            for _, zone in next, catchZones do
                local dist = (ball.Position - zone.Position).Magnitude

                if State.autoCatch.Value and dist <= Config.autoCatchRadius then
                    task.delay(Config.autoCatchDelay, function()
                        if State.autoCatch.Value then
                            replicatedStorage.Remotes.CharacterSoundEvent:FireServer(
                                "PlayerActions", 
                                isPractice and "catch " or "catch"
                            )
                        end
                    end)
                end

                if State.autoSwat.Value and dist <= Config.autoSwatRadius then
                    task.delay(Config.autoSwatDelay, function()
                        if State.autoSwat.Value then
                            replicatedStorage.Remotes.CharacterSoundEvent:FireServer("PlayerActions", "swat")
                        end
                    end)
                end

                if State.autoReflexJump.Value and dist <= Config.autoReflexJumpRadius then
                    if tick() - ReflexEngine.lastJump >= ReflexEngine.cooldown then
                        ReflexEngine.lastJump = tick()
                        humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                    end
                end
            end
        end
    end)

