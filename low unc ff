local function _godFindGameWeather()
	local now = tick()
	if _skyWeatherLastCheck ~= 0 and (now - _skyWeatherLastCheck) < 5 then
		return _skyWeatherCache
	end
	_skyWeatherLastCheck = now
	_skyWeatherCache = nil
	local direct = workspace:FindFirstChild("SkyWeather")
	if not direct and workspace:FindFirstChild("Models") then
		direct = workspace.Models:FindFirstChild("SkyWeather")
	end
	if not direct then
		pcall(function()
			direct = workspace:FindFirstChild("SkyWeather", true)
		end)
	end
	if direct then
		_skyWeatherCache = direct
	end
	return _skyWeatherCache
end

local function _godUpdateWeather()
	local wanted = string.lower(tostring(weatherType.Value or ""))
	local gameWeather = _godFindGameWeather()

	if gameWeather then

		for _, particle in next, gameWeather:GetDescendants() do
			if particle:IsA("ParticleEmitter") then
				local name = string.lower(particle.Name or "")
				particle.Enabled = changeWeather.Value and wanted ~= "" and string.find(name, wanted, 1, true) ~= nil
			end
		end
		if _customWeatherFolder then
			_godDestroyCustomWeather()
		end
		return
	end

	if changeWeather.Value and (wanted == "rain" or wanted == "snow" or wanted == "confetti") then
		if _customWeatherKind ~= wanted then
			_godBuildCustomWeather(wanted)
		end
	else
		_godDestroyCustomWeather()
	end
end

task.spawn(function()
	while true do
		task.wait(.5)
		local ok = pcall(_godUpdateWeather)
		if not ok then
			task.wait(1)
		end
	end
end)


