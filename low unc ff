    local head = character and character:FindFirstChild('Head')
    if not head then return end
    local originPos = head.Position

    local style = tostring((catchEffectStyle and catchEffectStyle.Value) or 'Classic Burst')
    if style == 'Shockwave Ring' then
        _fxShockwave(originPos)
    elseif style == 'Firework' then
        _fxFirework(originPos)
    elseif style == 'Confetti' then
        _fxConfetti(originPos)
    elseif style == 'Rainbow Aura' then
        _fxRainbowAura(originPos)
    else
        _fxClassic(originPos)
    end
end
