local findClosestBall = function()
    local character = player.Character
    if not character then return end

    local humanoidRootPart = character:FindFirstChild('HumanoidRootPart')
    if not humanoidRootPart then return end

    local dist = math.huge
    local ball = nil

    for _, v in next, workspace:GetChildren() do
        if not v:IsA('BasePart') then continue end
        if v.Name ~= 'Football' then continue end

        local distance = (v.Position - humanoidRootPart.Position).Magnitude

        if distance < dist then
            dist = distance
            ball = v
        end
    end

    return ball
end

local selectedRange = function()
	local range = tonumber(magnetsRadius.Value) or 0
	local mode = tostring(magsType.Value or 'Custom'):lower()

	if mode == 'legit' then
		return range / 2
	elseif mode == 'league' then
		return range / 1.4
	elseif mode == 'blatant' then
		return range * 1.5
	end

	return range
end

local TOUCH_PAIR_COOLDOWN = 0.2
local TOUCH_DELAY_MIN = 0.15
local TOUCH_DELAY_MAX = 0.35
local touchPairState = setmetatable({}, {__mode = 'k'})

local getTouchPairState = function(touchPart, ball)
    local partState = touchPairState[touchPart]
    if not partState then
        partState = setmetatable({}, {__mode = 'k'})
        touchPairState[touchPart] = partState
    end

    local pairState = partState[ball]
    if not pairState then
        pairState = {
            lastFire = 0,
            pending = false
        }
        partState[ball] = pairState
    end

    return pairState
end

local queueFireTouchPair = function(touchPart, ball)
    if not touchPart or not ball then return end
    if not touchPart.Parent or not ball.Parent then return end

    local pairState = getTouchPairState(touchPart, ball)
    local now = tick()

    if pairState.pending then return end
    if now - pairState.lastFire < TOUCH_PAIR_COOLDOWN then return end

    pairState.pending = true
    local randomDelay = TOUCH_DELAY_MIN + (math.random() * (TOUCH_DELAY_MAX - TOUCH_DELAY_MIN))

    task.delay(randomDelay, function()
        if not touchPart or not ball then
            pairState.pending = false
            return
        end
        if not touchPart.Parent or not ball.Parent then
            pairState.pending = false
            return
        end

        local fireNow = tick()
        if fireNow - pairState.lastFire >= TOUCH_PAIR_COOLDOWN then
            pairState.lastFire = fireNow
            pcall(function()
                firetouchinterest(touchPart, ball, 0)
                firetouchinterest(touchPart, ball, 1)
            end)
        end

        pairState.pending = false
    end)
end

