    -- ═══════════════════════════════════════════════════════════════
    RunService.RenderStepped:Connect(function()
        if not State.visualizeRushing.Value then
            RushVisuals:HideAll()
            return
        end

        local character = player.Character
        local root = character and character:FindFirstChild("HumanoidRootPart")
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        local camera = workspace.CurrentCamera

        if not (root and humanoid and camera) then
            RushVisuals:HideAll()
            return
        end

        local targetRoot, targetHum = Predictor.GetBallCarrier()
        if not targetRoot then
            RushVisuals:HideAll()
            return
        end

        local selfPos, selfVis = camera:WorldToViewportPoint(root.Position)
        local tgtPos, tgtVis = camera:WorldToViewportPoint(targetRoot.Position)

        if not (selfVis and tgtVis) then
            RushVisuals:HideAll()
            return
        end

        local selfVec = Vector2.new(selfPos.X, selfPos.Y)
        local tgtVec = Vector2.new(tgtPos.X, tgtPos.Y)

        -- Main line to target
        if RushVisuals.elements.line then
            RushVisuals.elements.line.From = selfVec
            RushVisuals.elements.line.To = tgtVec
            RushVisuals.elements.line.Visible = true
        end
        RushVisuals:OrientArrow(RushVisuals.elements.arrow, tgtVec, tgtVec - selfVec, 16)

        -- Target circle
        if RushVisuals.elements.circle then
            RushVisuals.elements.circle.Position = tgtVec
            RushVisuals.elements.circle.Visible = true
        end

        -- Carrier movement prediction
        local hMove = targetHum.MoveDirection
        if hMove.Magnitude > 0.01 and RushVisuals.elements.holderLine then
            local fPos, fVis = camera:WorldToViewportPoint(targetRoot.Position + (hMove * 6))
            if fVis then
                local fVec = Vector2.new(fPos.X, fPos.Y)
                RushVisuals.elements.holderLine.From = tgtVec
                RushVisuals.elements.holderLine.To = fVec
                RushVisuals.elements.holderLine.Visible = true
                RushVisuals:OrientArrow(RushVisuals.elements.holderArrow, fVec, fVec - tgtVec, 13)
            else
                RushVisuals.elements.holderLine.Visible = false
                if RushVisuals.elements.holderArrow then RushVisuals.elements.holderArrow.Visible = false end
            end
        else
            if RushVisuals.elements.holderLine then RushVisuals.elements.holderLine.Visible = false end
            if RushVisuals.elements.holderArrow then RushVisuals.elements.holderArrow.Visible = false end
        end

        -- Self movement indicator
        local myMove = humanoid.MoveDirection
        if myMove.Magnitude > 0.01 and RushVisuals.elements.moveLine then
            local mPos, mVis = camera:WorldToViewportPoint(root.Position + (myMove * 6))
            if mVis then
                local mVec = Vector2.new(mPos.X, mPos.Y)
                RushVisuals.elements.moveLine.From = selfVec
                RushVisuals.elements.moveLine.To = mVec
                RushVisuals.elements.moveLine.Visible = true
                RushVisuals:OrientArrow(RushVisuals.elements.moveArrow, mVec, mVec - selfVec, 13)
            else
                RushVisuals.elements.moveLine.Visible = false
                if RushVisuals.elements.moveArrow then RushVisuals.elements.moveArrow.Visible = false end
            end
        else
            if RushVisuals.elements.moveLine then RushVisuals.elements.moveLine.Visible = false end
            if RushVisuals.elements.moveArrow then RushVisuals.elements.moveArrow.Visible = false end
        end
    end)

