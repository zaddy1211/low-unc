    runService.RenderStepped:Connect(function()
        if not State.enableQbAimbot then
            HUDEngine.SetVisibility(false)
            HighlightEngine.Update()
            BeamEngine.Hide()
            ThrowState.target = nil
            return
        end

        local char = lp.Character
        if not char then return end

        local head = char:FindFirstChild('Head')
        local hrp = char:FindFirstChild('HumanoidRootPart')
        if not head or not hrp then return end

        local football = char:FindFirstChild('Football')
        local hasFootball = football ~= nil

        if hasFootball then
            football:SetAttribute('LocalAimbotBall', true)
            local fHandle = football:FindFirstChild('Handle')
            if fHandle then fHandle:SetAttribute('LocalAimbotBall', true) end
        end

        local playerGui = lp:WaitForChild('PlayerGui', 10)
        local ballGui = playerGui and playerGui:FindFirstChild('BallGui')

        if State.autoJuke and hasFootball and ballGui then
            local bounds = JukeEngine.GetFieldBounds()
            local myVel = hrp.AssemblyLinearVelocity or Vector3.zero
            local dodgeVec, threatCount = JukeEngine.CalculateDodgeVector(hrp, myVel)
            local checkPos = hrp.Position
            local outOfBoundsPush = JukeEngine.GetOOBPush(checkPos, bounds)

            local hum = char:FindFirstChildOfClass('Humanoid')
            if hum then
                local targetJukeDir = Vector3.zero
                if threatCount > 0 then
                    targetJukeDir = dodgeVec.Unit
                    if outOfBoundsPush.Magnitude > 0 then
                        targetJukeDir = (targetJukeDir + outOfBoundsPush * 2).Unit
                    end
                elseif outOfBoundsPush.Magnitude > 0 then
                    targetJukeDir = outOfBoundsPush.Unit
                end

                if targetJukeDir.Magnitude > 0 then
                    ThrowState.smoothedJukeDir = ThrowState.smoothedJukeDir:Lerp(targetJukeDir, 0.25)
                    hum:Move(ThrowState.smoothedJukeDir, false)
                else
                    ThrowState.smoothedJukeDir = Vector3.zero
                end
            end
        end

        local isTracking = hasFootball and (ballGui ~= nil)

        if isTracking then
            if not State.hideCards then
                HUDEngine.SetVisibility(true)
            else
                HUDEngine.SetVisibility(false)
            end

            if not ThrowState.isThrowingAway then
                local newTarget = TargetEngine.GetTarget()
                if newTarget then
                    ThrowState.lastValidTarget = newTarget
                elseif ThrowState.lastValidTarget and not ThrowState.lastValidTarget:FindFirstChild('HumanoidRootPart') then
                    ThrowState.lastValidTarget = nil
                end

                if State.throwAimbot then
                    ThrowState.target = ThrowState.lastValidTarget
                    HighlightEngine.Update()

                    local targetPos
                    local mouseHit = lp:GetMouse()
                    if ThrowState.isThrowing and ThrowState.lockedMousePos then
                        targetPos = ThrowState.lockedMousePos
                    else
                        targetPos = mouseHit.Hit.Position
                        ThrowState.lockedMousePos = targetPos
                    end

                    local headPos = head.Position
                    local calcPower, calcAngle = Kinematics.Solve(headPos, targetPos, GRAVITY)
                    calcPower = tonumber(calcPower) or MAX_POWER
                    calcAngle = tonumber(calcAngle) or 45

                    if State.autoPower then
                        ThrowState.power = math.clamp(calcPower, 0, MAX_POWER)
                    end
                    if State.autoAngle then
                        ThrowState.angle = math.clamp(calcAngle, -15, 90)
                    else
                        ThrowState.angle = math.clamp(tonumber(Config.customHeight) or 0, -15, 90)
                    end

                    local safePower = tonumber(ThrowState.power) or 60
                    local safeAngle = tonumber(ThrowState.angle) or 45
                    local angleRad = tonumber(math.rad(safeAngle)) or 0

                    local hDirRaw = Vector3.new(targetPos.X - headPos.X, 0, targetPos.Z - headPos.Z)
                    local hDir = hDirRaw.Magnitude > 0.01 and hDirRaw.Unit or hrp.CFrame.LookVector
                    local dirVelocity = (hDir * (tonumber(math.cos(angleRad)) or 1) + Vector3.new(0, tonumber(math.sin(angleRad)) or 0, 0)) * safePower
                    ThrowState.direction = dirVelocity.Unit * safePower

                    local hVel = safePower * (tonumber(math.cos(angleRad)) or 1)
                    if hVel > 0.1 then
                        local xDist = tonumber(Vector3.new(targetPos.X - headPos.X, 0, targetPos.Z - headPos.Z).Magnitude) or 0
                        ThrowState.airtime = xDist / hVel
                    else
                        ThrowState.airtime = 0
                    end

                    ThrowState.targetLeadPos = targetPos
                else
                    ThrowState.target = newTarget or ThrowState.lastValidTarget
                    HighlightEngine.Update()

                    if ThrowState.target and hrp then
                        local tHRP = ThrowState.target:FindFirstChild('HumanoidRootPart')
                        if tHRP then
                            if State.autoSelectThrowMode then
                                local m = ModeEngine.GetRecommendedMode(ThrowState.target)
                                ModeEngine.SetMode(m)
                            end
                            AimEngine.SolveAim(tHRP)
                        end
                    end
                end
            else
                ThrowState.target = nil
                HighlightEngine.Update()
            end

            HUDEngine.UpdateCards()

            if State.autoChangePowerUI and ballGui and ballGui:FindFirstChild('Frame0') then
                local frame0 = ballGui.Frame0
                local powerBar = frame0:FindFirstChild('Power') or frame0:FindFirstChild('Frame2')
                if powerBar then
                    local safePower = tonumber(ThrowState.power) or 60
                    for _, bar in next, (powerBar:GetChildren()) do
                        if bar:IsA('Frame') then
                            bar.Size = UDim2.new(safePower / 100, 0, 1, 0)
                        end
                    end
                end
            end

            if ThrowState.target or State.throwAimbot then
                local startOrigin = head.Position
                local drawDir, drawAirtime

                if State.throwAimbot then
                    local mousePos = lp:GetMouse().Hit.Position
                    local dirToTarget = mousePos - startOrigin
                    local safePowerForBeam = tonumber(ThrowState.power) or 60
                    local safeAngle = tonumber(ThrowState.angle) or 45
                    local angleRad = tonumber(math.rad(safeAngle)) or 0
                    local hDir = Vector3.new(dirToTarget.X, 0, dirToTarget.Z)
                    hDir = hDir.Magnitude > 0.01 and hDir.Unit or hrp.CFrame.LookVector
                    local dirVelocity = (hDir * (tonumber(math.cos(angleRad)) or 1) + Vector3.new(0, tonumber(math.sin(angleRad)) or 0, 0)) * safePowerForBeam
                    drawDir = dirVelocity.Unit * safePowerForBeam
                    ThrowState.direction = drawDir

                    local hVel = safePowerForBeam * (tonumber(math.cos(angleRad)) or 1)
                    if hVel > 0.1 then
                        local xDist = tonumber(Vector3.new(mousePos.X - startOrigin.X, 0, mousePos.Z - startOrigin.Z).Magnitude) or 0
                        drawAirtime = xDist / hVel
                    else
                        drawAirtime = 0
                    end
                    ThrowState.airtime = drawAirtime
                else
                    drawDir = ThrowState.direction or Vector3.new(0, 1, 0)
                    if (tonumber(drawDir.Magnitude) or 0) < 0.1 then
                        drawDir = Vector3.new(0, 1, 0) * 60
                    end
                    drawAirtime = ThrowState.airtime or 0.1
                end

                BeamEngine.Update(startOrigin, drawDir, drawAirtime)
            else
                BeamEngine.Hide()
            end
        else
            HUDEngine.SetVisibility(false)
            HighlightEngine.Update()
            BeamEngine.Hide()
            ThrowState.target = nil
            ThrowState.lockedMousePos = nil
        end
    end)

