    -- TARGET SELECTION ENGINE
    -- ═══════════════════════════════════════════════════════════════
    local TargetEngine = {}

    function TargetEngine.GetPotentialTargets()
        local targets = {}

        for _, plr in next, players:GetPlayers() do
            if plr ~= lp and plr.Character and plr.Character:FindFirstChild('HumanoidRootPart') then
                local eHum = plr.Character:FindFirstChildOfClass('Humanoid')
                if not eHum or not eHum.Sit then
                    if TeamChecker:IsTeammate(plr) then
                        table.insert(targets, plr.Character)
                    end
                end
            end
        end

        for _, bot in next, BotFinder.GetActiveBots() do
            if bot:FindFirstChild('HumanoidRootPart') then
                local eHum = bot:FindFirstChildOfClass('Humanoid')
                if not eHum or not eHum.Sit then
                    table.insert(targets, bot)
                end
            end
        end

        return targets
    end

    function TargetEngine.GetBestOpenTarget()
        local bestTarget, bestDist = nil, math.huge
        local qbHRP = lp.Character and lp.Character:FindFirstChild('HumanoidRootPart')
        local qbPos = qbHRP and qbHRP.Position or Vector3.zero
        local mousePos2D = userInputService:GetMouseLocation()

        for _, char in next, TargetEngine.GetPotentialTargets() do
            local hrp = char:FindFirstChild('HumanoidRootPart')
            if hrp then
                local _, onScreen = camera:WorldToViewportPoint(hrp.Position)
                if onScreen and CoverageEngine.CheckDB(char) then
                    local dist = tonumber((hrp.Position - qbPos).Magnitude) or 0
                    if dist < bestDist then
                        bestDist = dist
                        bestTarget = char
                    end
                end
            end
        end

        return bestTarget
    end

    function TargetEngine.GetMouseClosestTarget()
        local bestTarget, bestMouseDist = nil, math.huge
        local mousePos2D = userInputService:GetMouseLocation()

        for _, char in next, TargetEngine.GetPotentialTargets() do
            local hrp = char:FindFirstChild('HumanoidRootPart')
            if hrp then
                local screenPos, onScreen = camera:WorldToViewportPoint(hrp.Position)
                if onScreen then
                    local dist = tonumber((Vector2.new(screenPos.X, screenPos.Y) - mousePos2D).Magnitude) or 0
                    if dist < bestMouseDist then
                        bestMouseDist = dist
                        bestTarget = char
                    end
                end
            end
        end

        return bestTarget
    end

    function TargetEngine.GetTarget()
        if ThrowState.isThrowing and ThrowState.target then
            return ThrowState.target
        end

        if ThrowState.targetLocked and ThrowState.lockedTarget 
            and ThrowState.lockedTarget:FindFirstChild('HumanoidRootPart') then
            return ThrowState.lockedTarget
        elseif ThrowState.targetLocked then
            ThrowState.targetLocked = false
            ThrowState.lockedTarget = nil
        end

        if State.autoChooseWr then
            local openTarget = TargetEngine.GetBestOpenTarget()
            if openTarget then return openTarget end
        end

        return TargetEngine.GetMouseClosestTarget()
    end

    -- ═══════════════════════════════════════════════════════════════
    -- MODE SELECTION ENGINE
    -- ═══════════════════════════════════════════════════════════════
    local ModeEngine = {}

    function ModeEngine.GetRecommendedMode(targetChar)
        if not targetChar then return 'Mag' end
        
        local targetHRP = targetChar:FindFirstChild('HumanoidRootPart')
        if not targetHRP then return 'Mag' end

        local lpChar = lp.Character
        local lpHRP = lpChar and lpChar:FindFirstChild('HumanoidRootPart')
        if not lpHRP then return 'Mag' end

        local route, _ = RouteEngine.Analyze(targetChar)
        local dist = tonumber((targetHRP.Position - lpHRP.Position).Magnitude) or 0
        if dist < 40 then return 'Bullet' end

        local dbDistance = math.huge
        for _, plr in next, players:GetPlayers() do
            if plr ~= lp and plr.Character and TeamChecker:IsEnemy(plr) then
                local eHRP = plr.Character:FindFirstChild('HumanoidRootPart')
                if eHRP and eHRP ~= targetHRP then
                    local d = tonumber((eHRP.Position - targetHRP.Position).Magnitude) or 0
                    if d < dbDistance then dbDistance = d end
                end
            end
        end

        for _, bot in next, BotFinder.GetActiveBots() do
            local bHRP = bot:FindFirstChild('HumanoidRootPart')
            if bHRP and bHRP ~= targetHRP then
                local d = tonumber((bHRP.Position - targetHRP.Position).Magnitude) or 0
                if d < dbDistance then dbDistance = d end
            end
        end

        local forwardRoutes = {['go/fade'] = true, ['post/corner'] = true, seam = true, 
            ['curl/comeback'] = true, stationary = true}
        local sidewayRoutes = {['in/out'] = true, flat = true, wheel = true}

        if route == 'slant' or route == 'drag' or route == 'in/out' or route == 'flat' then
            return 'Bullet'
        elseif forwardRoutes[route] then
            if dbDistance > 5 then
                return ((tonumber(ThrowState.angle) or 45) < 40) and 'Jump' or 'Dime'
            elseif dbDistance > 2 then
                return 'Dive'
            end
            return 'Mag'
        elseif sidewayRoutes[route] then
            if dbDistance > 4 then return 'Dime' end
            return 'Jump'
        end
        return 'Dime'
    end

    function ModeEngine.SetMode(modeName)
        for i = 1, #MODE_ORDER do
            if MODE_ORDER[i] == modeName then
                ThrowState.modeIndex = i
                return
            end
        end
    end

    -- ═══════════════════════════════════════════════════════════════
    -- KINEMATICS ENGINE
    -- ═══════════════════════════════════════════════════════════════
    local Kinematics = {}

    function Kinematics.Solve(origin, targetPos, gravityMag)
        local g = tonumber(gravityMag) or GRAVITY
        local displacement = targetPos - origin
        local x = tonumber(Vector3.new(displacement.X, 0, displacement.Z).Magnitude) or 0
        local y = tonumber(displacement.Y) or 0

        local inner = (x^2) + (y^2)
        local root = tonumber(math.sqrt(math.max(inner, 0))) or 0

        local baseAngleRad = math.rad(45)
        if x > 0.01 then
            local atanRes = tonumber(math.atan((y + root) / x)) or baseAngleRad
            if atanRes == atanRes then baseAngleRad = atanRes end
        end

        local angleRad = tonumber(math.clamp(baseAngleRad * 0.85, math.rad(-15), math.rad(65))) or 0
        local cosA = tonumber(math.cos(angleRad)) or 1
        local tanA = tonumber(math.tan(angleRad)) or 0

        local v0 = 95
        local denom = 2 * (cosA^2) * (x * tanA - y)
        if denom > 0.001 then
            local res = tonumber(math.sqrt((g * x^2) / denom)) or v0
            if res == res and res ~= math.huge then v0 = res end
        end

        return v0, tonumber(math.deg(angleRad)) or 45
    end

    function Kinematics.SolveHighPower(origin, targetPos)
        local displacement = targetPos - origin
        local x = tonumber(Vector3.new(displacement.X, 0, displacement.Z).Magnitude) or 0
        local y = tonumber(displacement.Y) or 0

        local v2 = MAX_POWER^2
        local v4 = MAX_POWER^4
        local gx = GRAVITY * x
        local discriminant = v4 - GRAVITY * (GRAVITY * x^2 + 2 * y * v2)

        if discriminant >= 0 then
            return tonumber(math.clamp(
                math.deg(math.atan((v2 - math.sqrt(discriminant)) / gx)) * 0.94, 
                -15, 85
            )) or 45
        end
        return 45
    end

    function Kinematics.SolveBullet(origin, targetPos)
        local displacement = targetPos - origin
        local h = tonumber(Vector3.new(displacement.X, 0, displacement.Z).Magnitude) or 0
        local v = tonumber(displacement.Y) or 0
        local t_est = h / MAX_POWER
        local drop = 0.5 * GRAVITY * t_est * t_est
        return tonumber(math.clamp(math.deg(math.atan2(v + drop, h)), -15, 45)) or 15
    end

    function Kinematics.BeamProjectile(g, v0, x0, t1)
        local safeT1 = tonumber(t1) or 0.1
        local p3 = 0.5 * g * safeT1 * safeT1 + v0 * safeT1 + x0
        local p2 = p3 - (g * safeT1 * safeT1 + v0 * safeT1) / 3
        local c = 0.5 * 0.5 * 0.5
        local p1 = (c * g * safeT1 * safeT1 + 0.5 * v0 * safeT1 + x0 - c * (x0 + p3)) / (3 * c) - p2

        local curve0 = tonumber((p1 - x0).Magnitude) or 0
        local curve1 = tonumber((p2 - p3).Magnitude) or 0

        local b = (x0 - p3).Unit
        local r1 = (p1 - x0).Unit
        local u1 = r1:Cross(b).Unit
        local r2 = (p2 - p3).Unit
        local u2 = r2:Cross(b).Unit
        b = u1:Cross(r1).Unit

        local cf1 = CFrame.new(x0.X, x0.Y, x0.Z, r1.X, u1.X, b.X, r1.Y, u1.Y, b.Y, r1.Z, u1.Z, b.Z)
        local cf2 = CFrame.new(p3.X, p3.Y, p3.Z, r2.X, u2.X, b.X, r2.Y, u2.Y, b.Y, r2.Z, u2.Z, b.Z)

        return curve0, -curve1, cf1, cf2
    end

    -- ═══════════════════════════════════════════════════════════════
    -- THREAT ANALYSIS ENGINE
    -- ═══════════════════════════════════════════════════════════════
    local ThreatEngine = {}

    function ThreatEngine.GetClosestEnemy(targetHRP)
        local closestDist, closestPos = math.huge, nil

        local function processEnemy(char)
            local eHRP = char:FindFirstChild('HumanoidRootPart')
            if not eHRP then return end
            local dist = tonumber((eHRP.Position - targetHRP.Position).Magnitude) or 0
            if dist < closestDist then
                closestDist = dist
                closestPos = eHRP.Position
            end
        end

        for _, plr in next, players:GetPlayers() do
            if plr ~= lp and plr.Character and TeamChecker:IsEnemy(plr) then
                processEnemy(plr.Character)
            end
        end

        for _, bot in next, BotFinder.GetActiveBots() do
            processEnemy(bot)
        end

        return closestDist, closestPos
    end

    function ThreatEngine.CalculateThreatFactor(targetHRP, moveDir)
        local closestDist, closestPos = ThreatEngine.GetClosestEnemy(targetHRP)
        local threatFactor = 0.5

        if closestPos then
            local distFactor = math.clamp(1 - closestDist / 15, 0, 1)
            local moveDirFlat = Vector3.new(moveDir.X, 0, moveDir.Z)
            local posFactor = 0

            if moveDirFlat.Magnitude > 0.01 then
                local toEnemy = closestPos - targetHRP.Position
                local dirToEnemy = Vector3.new(toEnemy.X, 0, toEnemy.Z)
                if dirToEnemy.Magnitude > 0.01 then
                    posFactor = math.clamp(dirToEnemy.Unit:Dot(moveDirFlat.Unit) * 0.3, -0.3, 0.3)
                end
            end

            threatFactor = math.clamp(distFactor + posFactor, 0, 1)
        else
            local distToTarget = 0
            local lpChar = lp.Character
            local lpHRP = lpChar and lpChar:FindFirstChild('HumanoidRootPart')
            if lpHRP then
                distToTarget = (targetHRP.Position - lpHRP.Position).Magnitude
            end
            local variation = math.clamp(distToTarget / 200, 0, 1)
            threatFactor = 0.3 + variation * 0.4
        end

        return threatFactor
    end

    -- ═══════════════════════════════════════════════════════════════
    -- ANTI-DB ENGINE
    -- ═══════════════════════════════════════════════════════════════
    local AntiDBEngine = {}

    function AntiDBEngine.PushLeadAway(leadPos, threshold)
        local pushVec = Vector3.zero

        local function processEnemy(char)
            local eHRP = char:FindFirstChild('HumanoidRootPart')
            if not eHRP then return end
            local dist = tonumber(Vector3.new(eHRP.Position.X - leadPos.X, 0, eHRP.Position.Z - leadPos.Z).Magnitude) or 0
            if dist < threshold then
                local away = Vector3.new(leadPos.X - eHRP.Position.X, 0, leadPos.Z - eHRP.Position.Z)
                if away.Magnitude > 0 then
                    pushVec = pushVec + (away.Unit * (threshold - dist))
                end
            end
        end

        for _, plr in next, players:GetPlayers() do
            if plr ~= lp and plr.Character and TeamChecker:IsEnemy(plr) then
                processEnemy(plr.Character)
            end
        end

        for _, bot in next, BotFinder.GetActiveBots() do
            processEnemy(bot)
        end

        return pushVec
    end

    -- ═══════════════════════════════════════════════════════════════
    -- ANTI-OOB ENGINE
    -- ═══════════════════════════════════════════════════════════════
    local AntiOOBEngine = {}

    function AntiOOBEngine.ClampPosition(leadPos, threshold)
        local fPos = Vector3.zero
        local field = workspace:FindFirstChild('Models')
        if field then field = field:FindFirstChild('Field') end
        if field then field = field:FindFirstChild('Ground') end
        if field then fPos = field.Position end

        if fPos == Vector3.zero then return leadPos end

        local halfWidth = 75 - threshold
        local halfLength = 175 - threshold

        return Vector3.new(
            math.clamp(leadPos.X, fPos.X - halfWidth, fPos.X + halfWidth),
            leadPos.Y,
            math.clamp(leadPos.Z, fPos.Z - halfLength, fPos.Z + halfLength)
        )
    end

    -- ═══════════════════════════════════════════════════════════════
    -- AIMING ENGINE
    -- ═══════════════════════════════════════════════════════════════
    local AimEngine = {}

    function AimEngine.CalculateLeadPosition(targetHRP)
        local lpChar = lp.Character
        local head = lpChar and lpChar:FindFirstChild('Head')
        local origin = head and head.Position or (lpChar and lpChar:FindFirstChild('HumanoidRootPart') and lpChar.HumanoidRootPart.Position) or Vector3.zero

        local targetChar = targetHRP.Parent
        local targetHeadObj = targetChar and targetChar:FindFirstChild('Head')
        local targetHead = targetHeadObj and targetHeadObj.Position or targetHRP.Position + Vector3.new(0, 1.5, 0)

        local moveDir = Vector3.zero
        local targetHum = targetChar and targetChar:FindFirstChildOfClass('Humanoid')
        if targetHum then
            local isBot = targetChar:FindFirstAncestor('npcwr') ~= nil
            if isBot then
                local wtpDiff = targetHum.WalkToPoint - targetHRP.Position
                local dir = Vector3.new(wtpDiff.X, 0, wtpDiff.Z)
                moveDir = dir.Magnitude > 0.1 and dir.Unit or Vector3.zero
            else
                local md = targetHum.MoveDirection
                local flatMd = Vector3.new(md.X, 0, md.Z)
                moveDir = flatMd.Magnitude > 0.01 and flatMd.Unit or Vector3.zero
            end
        end

        local ping = 0
        pcall(function() ping = tonumber(lp:GetNetworkPing()) or 0 end)
        local dataPing = 0
        pcall(function() dataPing = (tonumber(stats.Network.ServerStatsItem['Data Ping']:GetValue()) or 0) / 1000 end)
        if dataPing == 0 then dataPing = ping end
        ping = ping + dataPing

        local modeName = MODE_ORDER[ThrowState.modeIndex]
        local smartFitForThrow = State.smartFit and modeName ~= 'Bullet'

        local routeStr = ThrowState.target and select(1, RouteEngine.Analyze(ThrowState.target)) or 'go/fade'
        local isChestPass = modeName == 'Bullet' or (routeStr == 'slant' or routeStr == 'drag' or routeStr == 'in/out' or routeStr == 'flat' or routeStr == 'hitch' or routeStr == 'curl/comeback')

        local activePower = tonumber(ThrowState.power) or 60
        if modeName == 'Bullet' or (State.autoPower and isChestPass) or State.highPowerOnly then
            activePower = MAX_POWER
        end

        local lDivisor = 60
        if activePower > 75 then
            lDivisor = 60 + ((activePower - 75) * 1.5)
        end

        local distToTarget = tonumber((targetHRP.Position - origin).Magnitude) or 0
        local estFlightTime = distToTarget / (tonumber(lDivisor) or 60)

        local threatFactor = ThreatEngine.CalculateThreatFactor(targetHRP, moveDir)
        local dynamicLead = 4.2 + threatFactor * 7.8
        local dynamicHeight = 0.4 + threatFactor * 2.6

        if smartFitForThrow then
            local timeVar = math.sin(tick() * 2) * 1.5
            dynamicLead = dynamicLead + timeVar
            dynamicHeight = dynamicHeight + math.sin(tick() * 2 + 1) * 0.5
        end

        local leadOffset = smartFitForThrow and dynamicLead or (tonumber(Config.throwLeadOffset) or 0)
        local heightOffset = smartFitForThrow and dynamicHeight or (tonumber(Config.throwHeightOffset) or 0)

        if modeName == 'Bullet' then
            heightOffset = math.max(tonumber(heightOffset) or 0, 0.3)
        end

        local modeLeadScale = (tonumber(MODE_LEADS[modeName]) or 8.6) * 3.05
        local selectedModeYLead = tonumber(MODE_Y_LEADS[modeName]) or 0
        local rMult = tonumber(ROUTE_MULTIPLIERS[routeStr]) or 1.0

        local dirUnit = moveDir.Magnitude > 0.01 and moveDir.Unit or Vector3.zero
        local targetBase = (isChestPass or modeName == 'Bullet') and targetHRP.Position or targetHead
        local standingStill = (routeStr == 'stationary')

        local leadPos
        if standingStill then
            leadPos = targetHead
        else
            leadPos = targetBase + (moveDir * 20 * estFlightTime * rMult) + (moveDir * 20 * ping * rMult) + (dirUnit * modeLeadScale * rMult)
            leadPos = leadPos + (dirUnit * leadOffset)

            if isChestPass or modeName == 'Bullet' then
                leadPos = Vector3.new(leadPos.X, targetHead.Y, leadPos.Z)
                if modeName == 'Bullet' then
                    leadPos = leadPos + Vector3.new(0, -2, 0)
                end
                selectedModeYLead = 0
            end

            leadPos = leadPos + Vector3.new(0, selectedModeYLead, 0)
            leadPos = leadPos + Vector3.new(0, heightOffset, 0)

            if routeStr == 'curl/comeback' or routeStr == 'hitch' then
                leadPos = leadPos + Vector3.new(0, -5, 0)
            end
        end

        local forceAutoAngle = modeName == 'Bullet' or isChestPass or (tonumber(ThrowState.power) or 60) == MAX_POWER or State.highPowerOnly
        if not State.autoAngle and not forceAutoAngle then
            leadPos = leadPos + Vector3.new(0, tonumber(Config.customHeight) or 0, 0)
        end

        if State.antiDB or smartFitForThrow then
            local threshold = smartFitForThrow and 5.0 or (tonumber(Config.antiDBThreshold) or 15)
            leadPos = AntiDBEngine.PushLeadAway(leadPos, threshold) + leadPos
        end

        if State.antiOOB or smartFitForThrow then
            local threshold = smartFitForThrow and 3.4 or (tonumber(Config.antiOOBThreshold) or 5)
            leadPos = AntiOOBEngine.ClampPosition(leadPos, threshold)
        end

        return leadPos
    end

    function AimEngine.SolveAim(targetHRP)
        local lpChar = lp.Character
        local head = lpChar and lpChar:FindFirstChild('Head')
        local origin = head and head.Position or (lpChar and lpChar:FindFirstChild('HumanoidRootPart') and lpChar.HumanoidRootPart.Position) or Vector3.zero

        local leadPos = AimEngine.CalculateLeadPosition(targetHRP)
        ThrowState.targetLeadPos = leadPos

        local calcPower, calcAngle = Kinematics.Solve(origin, leadPos, GRAVITY)
        calcPower = tonumber(calcPower) or MAX_POWER
        calcAngle = tonumber(calcAngle) or 45

        local modeName = MODE_ORDER[ThrowState.modeIndex]
        local routeStr = ThrowState.target and select(1, RouteEngine.Analyze(ThrowState.target)) or 'go/fade'
        local isChestPass = modeName == 'Bullet' or (routeStr == 'slant' or routeStr == 'drag' or routeStr == 'in/out' or routeStr == 'flat' or routeStr == 'hitch' or routeStr == 'curl/comeback')
        local standingStill = (routeStr == 'stationary')

        if standingStill and modeName ~= 'Bullet' and not State.highPowerOnly then
            local dynamicThreshold = tonumber(math.clamp(4 + ((targetHRP.Position - origin).Magnitude * 0.08), 5, 14)) or 10
            if calcAngle > dynamicThreshold then
                local displacement = leadPos - origin
                local x = tonumber(Vector3.new(displacement.X, 0, displacement.Z).Magnitude) or 0
                local y = tonumber(displacement.Y) or 0
                local aRad = tonumber(math.rad(dynamicThreshold)) or 0.1
                local denom = 2 * (math.cos(aRad)^2) * (x * math.tan(aRad) - y)

                if denom > 0.001 then
                    local newPwr = tonumber(math.sqrt((GRAVITY * x^2) / denom)) or calcPower
                    if newPwr == newPwr and newPwr ~= math.huge then
                        calcAngle = dynamicThreshold
                        calcPower = newPwr
                    end
                end
            end
        end

        if State.highPowerOnly then
            ThrowState.power = MAX_POWER
            ThrowState.angle = Kinematics.SolveHighPower(origin, leadPos)
        elseif modeName == 'Bullet' or (State.autoPower and isChestPass) then
            ThrowState.power = MAX_POWER
            ThrowState.angle = Kinematics.SolveBullet(origin, leadPos)
        else
            if State.autoPower then
                ThrowState.power = tonumber(math.clamp(calcPower, 0, MAX_POWER)) or 60
            end
            if State.autoAngle then
                ThrowState.angle = tonumber(math.clamp(calcAngle, -15, 90)) or 45
            end
        end

        if not State.autoAngle and not (modeName == 'Bullet' or isChestPass or (tonumber(ThrowState.power) or 60) == MAX_POWER or State.highPowerOnly) then
            ThrowState.angle = tonumber(math.clamp(calcAngle, -15, 90)) or 45
        end

        local safePower = tonumber(ThrowState.power) or 60
        local safeAngle = tonumber(ThrowState.angle) or 45
        local angleRad = tonumber(math.rad(safeAngle)) or 0

        local hDirRaw = Vector3.new(leadPos.X - origin.X, 0, leadPos.Z - origin.Z)
        local hDir = hDirRaw.Magnitude > 0.01 and hDirRaw.Unit or (head and head.CFrame.LookVector or Vector3.new(0, 0, 1))

        local dirVelocity = (hDir * (tonumber(math.cos(angleRad)) or 1) + Vector3.new(0, tonumber(math.sin(angleRad)) or 0, 0)) * safePower
        ThrowState.direction = dirVelocity.Unit * safePower

        local hVel = safePower * (tonumber(math.cos(angleRad)) or 1)
        if hVel > 0.1 then
            local xDist = tonumber(Vector3.new(leadPos.X - origin.X, 0, leadPos.Z - origin.Z).Magnitude) or 0
            ThrowState.airtime = xDist / hVel
        else
            ThrowState.airtime = 0
        end

        return safeAngle
    end

