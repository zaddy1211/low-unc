    -- UTILITY — PREDICTION ENGINE
    -- ═══════════════════════════════════════════════════════════════
    local Predictor = {}

    function Predictor.GetPing()
        if not (stats and stats:FindFirstChild('Network') 
            and stats.Network:FindFirstChild('ServerStatsItem')
            and stats.Network.ServerStatsItem:FindFirstChild('Data Ping')) then
            return 0
        end
        return stats.Network.ServerStatsItem['Data Ping']:GetValue() / 1000
    end

    function Predictor.GetBallCarrier()
        local myChar = player.Character
        if not myChar then return nil end
        local myRoot = myChar:FindFirstChild("HumanoidRootPart")
        if not myRoot then return nil end

        local bestTarget, bestDist, bestHum = nil, math.huge, nil

        for _, v in next, players:GetPlayers() do
            if v == player or v.Team == player.Team or not v.Character then continue end

            local eChar = v.Character
            local eHrp = eChar:FindFirstChild("HumanoidRootPart")
            local eHum = eChar:FindFirstChildOfClass("Humanoid")
            if not (eHrp and eHum) then continue end
            if not eChar:FindFirstChild("Football") then continue end
            if eHum.WalkSpeed <= 0 or eHum.PlatformStand then continue end

            local dist = (eHrp.Position - myRoot.Position).Magnitude
            if dist < bestDist then
                bestDist = dist
                bestTarget = eHrp
                bestHum = eHum
            end
        end

        return bestTarget, bestHum, bestDist
    end

    function Predictor.ProjectPosition(origin, velocity, timeDelta)
        return origin + (velocity * timeDelta)
    end

    function Predictor.GetInterceptPosition(carrierRoot, carrierHum, reactionTime)
        local ping = Predictor.GetPing()
        local speed = carrierHum.MoveDirection.Magnitude > 0 and carrierHum.WalkSpeed or 0
        local predictionTime = ping + reactionTime

        local projected = carrierRoot.Position + (carrierHum.MoveDirection * speed * predictionTime * 20)
        local direction = projected - carrierRoot.Position

        if direction.Magnitude > 0 then
            projected += direction.Unit * ((carrierRoot.Position - projected).Magnitude / 20)
        end

        return projected
    end

    -- ═══════════════════════════════════════════════════════════════
    -- UTILITY — BALL FINDER
    -- ═══════════════════════════════════════════════════════════════
    local BallFinder = {}

    function BallFinder.GetClosestBall(position)
        local closest, closestDist = nil, math.huge
        for _, obj in next, workspace:GetChildren() do
            if not obj:IsA('BasePart') then continue end
            if not obj.Name:lower():find('ball') then continue end
            local dist = (obj.Position - position).Magnitude
            if dist < closestDist then
                closestDist = dist
                closest = obj
            end
        end
        return closest, closestDist
    end

    function BallFinder.GetCatchZones(character)
        local zones = {}
        for _, v in next, character:GetChildren() do
            if v:IsA("BasePart") and v.Name:lower():find("catch") then
                table.insert(zones, v)
            end
        end
        return zones
    end

