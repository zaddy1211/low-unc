local function LoadPhysicsTab()
    local PhysicsTab = Window:CreateTab({ 
        Name = 'Physics', 
        Icon = 'rbxassetid://11537490966' 
    })

    -- ═══════════════════════════════════════════════════════════════
    -- STATE & CONFIG MANAGER
    -- ═══════════════════════════════════════════════════════════════
    local State = {
        antiBoundaries = false,
        antiBench = false,
        endzoneReach = false,
        antiJam = false,
        antiJumpCooldown = false,
        antiFreeze = false,
        antiBlock = false,
        quickTP = false,
        bigHead = false,
    }

    local Config = {
        endzoneReachValue = 5,
        antiBlockActivation = 100,
        blockKnockbackForce = 0,
        quickTPPower = 0,
        bigHeadSize = 1,
    }

    -- ═══════════════════════════════════════════════════════════════
    -- BOUNDARY ENGINE — OOB MANIPULATION
    -- ═══════════════════════════════════════════════════════════════
    local BoundaryEngine = {
        boundaries = {},
        originalParent = nil,
    }

    function BoundaryEngine.Initialize()
        if isPractice then return end
        pcall(function()
            local b = workspace:FindFirstChild('Models') and workspace.Models:FindFirstChild('Boundaries')
            if not b then return end
            BoundaryEngine.originalParent = b
            for _, v in next, b:GetChildren() do
                table.insert(BoundaryEngine.boundaries, v)
            end
        end)
    end

    function BoundaryEngine.Toggle(enabled)
        for _, b in next, BoundaryEngine.boundaries do
            if b then
                b.Parent = enabled and nil or BoundaryEngine.originalParent
            end
        end
    end

    BoundaryEngine.Initialize()

    -- ═══════════════════════════════════════════════════════════════
    -- BENCH ENGINE — AUTO UNBENCH
    -- ═══════════════════════════════════════════════════════════════
    local BenchEngine = {}

    function BenchEngine.Check()
        local playerGui = player:FindFirstChild('PlayerGui')
        if not playerGui then return end

        local benchButton = playerGui:FindFirstChild('Benched', true)
        if not benchButton then return end

        if benchButton.BackgroundColor3 == Color3.fromRGB(120, 120, 120) then
            pcall(function()
                replicatedStorage.Remotes.CharacterSoundEvent:FireServer('Game', 'ToggleBench')
            end)
        end
    end

    function BenchEngine.Start()
        task.spawn(function()
            while true do
                task.wait()
                if not State.antiBench then continue end
                pcall(BenchEngine.Check)
            end
        end)
    end

    -- ═══════════════════════════════════════════════════════════════
    -- ENDZONE ENGINE — GOAL LINE EXTENSION
    -- ═══════════════════════════════════════════════════════════════
    local EndzoneEngine = {
        originalSizes = {},
        wasActive = false,
    }

    function EndzoneEngine.Restore()
        for endPart, originalSize in pairs(EndzoneEngine.originalSizes) do
            if endPart and endPart.Parent then
                endPart.Size = originalSize
            end
        end
    end

    function EndzoneEngine.Scan()
        for _, endPart in next, workspace:GetDescendants() do
            if not endPart:IsA('BasePart') then continue end
            if not (endPart.Name:lower()):find('linegoal') then continue end

            if not EndzoneEngine.originalSizes[endPart] then
                EndzoneEngine.originalSizes[endPart] = endPart.Size
            end

            local originalSize = EndzoneEngine.originalSizes[endPart]
            local zSize = Config.endzoneReachValue >= 10 and Config.endzoneReachValue or Config.endzoneReachValue / 10
            endPart.Size = Vector3.new(originalSize.X, originalSize.Y, zSize)
        end
    end

    function EndzoneEngine.Start()
        task.spawn(function()
            while true do
                task.wait(0.5)
                if not State.endzoneReach then
                    if EndzoneEngine.wasActive then
                        EndzoneEngine.Restore()
                        EndzoneEngine.wasActive = false
                    end
                    continue
                end
                EndzoneEngine.wasActive = true
                EndzoneEngine.Scan()
            end
        end)
    end

    -- ═══════════════════════════════════════════════════════════════
    -- COLLISION ENGINE — ANTI JAM / FREEZE / JUMP COOLDOWN
    -- ═══════════════════════════════════════════════════════════════
    local CollisionEngine = {}

    function CollisionEngine.ProcessAntiJam()
        for _, v in next, players:GetPlayers() do
            if v == player then continue end

            local character = v.Character
            if not character then continue end

            local hum = character:FindFirstChildOfClass('Humanoid')
            if not hum then continue end

            for _, part in next, character:GetChildren() do
                if not part:IsA('BasePart') then continue end
                if part.Name ~= 'Head' and part.Name ~= 'Torso' then continue end

                local shouldCollide = true
                if hum:GetState() == Enum.HumanoidStateType.Running then
                    shouldCollide = not State.antiJam
                end
                part.CanCollide = shouldCollide
            end
        end
    end

    function CollisionEngine.ProcessSelf()
        local char = player.Character
        if not char then return end

        local hum = char:FindFirstChildOfClass('Humanoid')
        if not hum then return end

        if State.antiJumpCooldown then
            hum:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
        end

        if State.antiFreeze and hum.WalkSpeed ~= 20 then
            hum.WalkSpeed = 20
        end
    end

    function CollisionEngine.Start()
        task.spawn(function()
            while true do
                task.wait()
                pcall(function()
                    CollisionEngine.ProcessSelf()
                    CollisionEngine.ProcessAntiJam()
                end)
            end
        end)
    end

    -- ═══════════════════════════════════════════════════════════════
    -- BLOCK RESIST ENGINE — ANTI BLOCK
    -- ═══════════════════════════════════════════════════════════════
    local BlockResistEngine = {}

    function BlockResistEngine.Process()
        local char = player.Character
        if not char then return end

        local hum = char:FindFirstChildOfClass('Humanoid')
        if not hum then return end

        local rootPart = char:FindFirstChild('HumanoidRootPart')
        if not rootPart then return end

        for _, descendant in next, char:GetDescendants() do
            if not descendant:IsA('BodyVelocity') then continue end

            -- Apply knockback
            if rootPart and Config.blockKnockbackForce > 0 then
                local moveDir = hum.MoveDirection
                if moveDir.Magnitude <= 0 then
                    moveDir = rootPart.CFrame.LookVector
                end
                rootPart.AssemblyLinearVelocity = moveDir * (15 * Config.blockKnockbackForce)
            end

            -- Destroy block velocity
            if math.random(1, 100) <= math.clamp(Config.antiBlockActivation, 0, 100) then
                descendant.Velocity = Vector3.zero
                descendant.MaxForce = Vector3.zero
                hum.WalkSpeed = 20
                pcall(function()
                    descendant:Destroy()
                end)
            end
        end
    end

    function BlockResistEngine.Start()
        task.spawn(function()
            while true do
                task.wait()
                if not State.antiBlock then continue end
                pcall(BlockResistEngine.Process)
            end
        end)
    end

    -- ═══════════════════════════════════════════════════════════════
    -- TELEPORT ENGINE — QUICK TP
    -- ═══════════════════════════════════════════════════════════════
    local TeleportEngine = {}

    function TeleportEngine.Trigger()
        local character = player.Character
        if not character then return end

        local hrp = character:FindFirstChild('HumanoidRootPart')
        if not hrp then return end

        hrp.CFrame += hrp.CFrame.LookVector * Config.quickTPPower
    end

    function TeleportEngine.Start()
        userInputService.InputBegan:Connect(function(input, gpe)
            if gpe then return end
            if not State.quickTP then return end
            if input.KeyCode ~= HideKeybind.Value and input.UserInputType ~= Enum.UserInputType.Touch then return end
            pcall(TeleportEngine.Trigger)
        end)
    end

    -- ═══════════════════════════════════════════════════════════════
    -- MORPH ENGINE — BIG HEAD
    -- ═══════════════════════════════════════════════════════════════
    local MorphEngine = {
        originalSizes = {},
    }

    function MorphEngine.Restore()
        for plr, size in pairs(MorphEngine.originalSizes) do
            local char = plr.Character
            if not char then continue end
            local head = char:FindFirstChild('Head')
            if not head then continue end
            head.Size = size
        end
        MorphEngine.originalSizes = {}
    end

    function MorphEngine.Process()
        for _, v in next, players:GetPlayers() do
            if v == player then continue end

            local character = v.Character
            if not character then continue end

            local head = character:FindFirstChild('Head')
            if not head then continue end

            if not MorphEngine.originalSizes[v] then
                MorphEngine.originalSizes[v] = head.Size
            end

            local targetSize = State.bigHead and Config.bigHeadSize or 1
            head.Size = Vector3.new(targetSize, targetSize, targetSize)
        end
    end

    function MorphEngine.Start()
        task.spawn(function()
            while true do
                task.wait()
                if not State.bigHead then
                    if next(MorphEngine.originalSizes) then
                        MorphEngine.Restore()
                    end
                    continue
                end
                pcall(MorphEngine.Process)
            end
        end)
    end

    -- ═══════════════════════════════════════════════════════════════
    -- INITIALIZE ENGINES
    -- ═══════════════════════════════════════════════════════════════
    BenchEngine.Start()
    EndzoneEngine.Start()
    CollisionEngine.Start()
    BlockResistEngine.Start()
    TeleportEngine.Start()
    MorphEngine.Start()

    -- ═══════════════════════════════════════════════════════════════
    -- UI BINDINGS
    -- ═══════════════════════════════════════════════════════════════
