				if moveDir.Magnitude <= 0 then
					moveDir = rootPart.CFrame.LookVector
				end
				rootPart.AssemblyLinearVelocity = moveDir * (15 * blockKnockbackForce.Value)
			end
			if math.random(1, 100) <= math.clamp(antiBlockActivation.Value, 0, 100) then
				F.Velocity = Vector3.zero
				F.MaxForce = Vector3.zero
				f.WalkSpeed = 20
				pcall(function()
