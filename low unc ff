        if gpe then return end
        
        local char = lp.Character
        if not char or not char:FindFirstChild('Football') then return end

        -- Throw ball away
        if input.KeyCode == Keybinds.throwAway then
            local fPos = Vector3.zero
            local field = workspace:FindFirstChild('Models')
            if field then field = field:FindFirstChild('Field') end
            if field then field = field:FindFirstChild('Ground') end
            if field then fPos = field.Position end

            local side = math.random(1, 2) == 1 and -1 or 1
            local throwTarget = fPos + Vector3.new(side * 120, 0, math.random(-100, 100))

            local head = char:FindFirstChild('Head')
            local origin = head and head.Position or char.HumanoidRootPart.Position

            ThrowState.isThrowingAway = true
            ThrowState.power = MAX_POWER
            ThrowState.angle = 25

            local angleRad = tonumber(math.rad(ThrowState.angle)) or 0
            local hDir = Vector3.new(throwTarget.X - origin.X, 0, throwTarget.Z - origin.Z).Unit
            local dirVelocity = (hDir * (tonumber(math.cos(angleRad)) or 1) + Vector3.new(0, tonumber(math.sin(angleRad)) or 0, 0)) * MAX_POWER
            ThrowState.direction = dirVelocity.Unit * MAX_POWER

            local hVel = MAX_POWER * (tonumber(math.cos(angleRad)) or 1)
            ThrowState.airtime = hVel > 0.1 and ((tonumber(Vector3.new(throwTarget.X - origin.X, 0, throwTarget.Z - origin.Z).Magnitude) or 0) / hVel) or 1

            local hum = char:FindFirstChildOfClass('Humanoid')
            local throwAnim = replicatedStorage:FindFirstChild('Animations') and replicatedStorage.Animations:FindFirstChild('Throw')
            if hum and throwAnim then
                local animator = hum:FindFirstChild('Animator')
                if animator then
                    local track = animator:LoadAnimation(throwAnim)
                    track:Play()
                end
            end
            return
        end

        -- Angle adjustment
        if input.KeyCode == Keybinds.increaseAngle then
            Config.customHeight = (tonumber(Config.customHeight) or 0) + 5
        elseif input.KeyCode == Keybinds.decreaseAngle then
            Config.customHeight = (tonumber(Config.customHeight) or 0) - 5
        end

        -- Mode keybinds
        if not State.autoSelectThrowMode then
            local modeMap = {
                [Keybinds.dime] = 'Dime',
                [Keybinds.mag] = 'Mag',
                [Keybinds.dive] = 'Dive',
                [Keybinds.jump] = 'Jump',
                [Keybinds.bullet] = 'Bullet',
            }
            local desiredMode = modeMap[input.KeyCode]
            if desiredMode then
                ModeEngine.SetMode(desiredMode)
            end
        end

        -- Lock target
        if input.KeyCode == Keybinds.lockTarget then
            if ThrowState.target or ThrowState.targetLocked then
                ThrowState.targetLocked = not ThrowState.targetLocked
                ThrowState.lockedTarget = ThrowState.targetLocked and ThrowState.target or nil
            end
        end
    end)

