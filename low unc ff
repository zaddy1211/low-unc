local ORIGINAL_ERROR = error
local ORIGINAL_PCALL = pcall
local ORIGINAL_XPCALL = xpcall

local function safeError(msg, level)
if isSensitive(msg) then return end
return ORIGINAL_ERROR(msg, level + 1)
end

local function safePcall(f, ...)
local args = table.pack(...)
return ORIGINAL_PCALL(function()
return f(table.unpack(args, 1, args.n))
end)
end

local function safeXpcall(f, handler, ...)
return ORIGINAL_XPCALL(f, function(err)
if isSensitive(err) then return true end
return handler and handler(err) or error(err)
end, ...)
end

