local distance = (currentPosition - lastPosition).Magnitude
if distance > 20 and timeDiff < 0.1 then
local midPoint = lastPosition:Lerp(currentPosition, 0.5)
hrp.CFrame = CFrame.new(midPoint, hrp.CFrame.LookVector)
task.wait(0.01)
hrp.CFrame = CFrame.new(currentPosition, hrp.CFrame.LookVector)
end

lastVelocity = currentVelocity
lastPosition = currentPosition
lastTime = currentTime
end)
