local function FFWrapControl(control, initial, onSet)
    local Element = { Value = initial }
    function Element:Set(val)
        Element.Value = val
        if control and control.Set then
            control.Set(val, false)
        end
        if onSet then task.spawn(function() pcall(onSet, val) end) end
    end
    function Element:GetValue()
        if control and control.Get then return control.Get() end
        return Element.Value
    end
    Element.GetValue = function() return Element:GetValue() end
    return Element
end

local function CreateFFTab(tabName)
    if not pages[tabName] then CreatePage(tabName) end
    local page = pages[tabName]
    local sectionCount = 0
    local function ensureSection(title)
        sectionCount = sectionCount + 1
        return Section(page, title or tabName, nil)
    end
    local currentCard = ensureSection(tabName)

    local Tab = { Name = tabName, Page = page.Scroll }

    function Tab:CreateDivider()
        Divider(page, currentCard)
    end

    -- Starts a labelled card within this tab. Existing controls remain compatible.
    function Tab:CreateSection(title)
        -- The tab starts with a default card for backwards compatibility.
        -- If the first action is a named section, replace that unused card.
        if sectionCount == 1 and currentCard and currentCard.Parent and #currentCard:GetChildren() == 3 then
            currentCard:Destroy()
        end
        currentCard = ensureSection(title or tabName)
        return currentCard
    end

    function Tab:CreateToggle(options)
        options = options or {}
        local name = options.Name or "Toggle"
        local default = options.Default == true
        local cb = options.Callback
        local Element = { Value = default }
        local control = Toggle(page, currentCard, name, default, function(state)
            Element.Value = state
            if cb then task.spawn(function() pcall(cb, state) end) end
        end)
        ConfigManager.Register(tabName .. "/" .. name, control)
        function Element:Set(val)
            Element.Value = val == true
            control.Set(Element.Value, false)
            if cb then task.spawn(function() pcall(cb, Element.Value) end) end
        end
        return Element
    end

    function Tab:CreateSlider(options)
        options = options or {}
        local name = options.Name or "Slider"
        local min = options.Min or 0
        local max = options.Max or 100
        local default = options.Default or min
        local suffix = options.Suffix or ""
        local cb = options.Callback
        local Element = { Value = default }
        local control = Slider(page, currentCard, name, min, max, default, suffix, function(v)
            Element.Value = v
            if cb then task.spawn(function() pcall(cb, v) end) end
        end)
        ConfigManager.Register(tabName .. "/" .. name, control)
        function Element:Set(val)
            Element.Value = val
            control.Set(val, false)
            if cb then task.spawn(function() pcall(cb, val) end) end
        end
        function Element:GetValue() return Element.Value end
        Element.GetValue = function() return Element.Value end
        return Element
    end

    function Tab:CreateDropdown(options)
        options = options or {}
        local name = options.Name or "Dropdown"
        local opts = options.Options or {}
        local default = options.Default
        if default == nil then default = opts[1] end
        local cb = options.Callback
        local Element = { Value = default }
        local control = Dropdown(page, currentCard, name, opts, default, function(v)
            Element.Value = v
            if cb then task.spawn(function() pcall(cb, v) end) end
        end)
        ConfigManager.Register(tabName .. "/" .. name, control)
        function Element:Set(val)
            Element.Value = val
            control.Set(val, false)
            if cb then task.spawn(function() pcall(cb, val) end) end
        end
        function Element:Refresh(newOpts)
            if control.Refresh then control.Refresh(newOpts) end
        end
        return Element
    end

    function Tab:CreateButton(options)
        options = options or {}
        local name = options.Name or "Button"
        local cb = options.Callback or function() end
        Button(page, currentCard, name, false, function()
            task.spawn(function() pcall(cb) end)
        end)
    end

    function Tab:CreateTextbox(options)
        options = options or {}
        local name = options.Name or "Textbox"
        local default = options.Default or ""
        local cb = options.Callback
        local Element = { Value = default }
        local control = Textbox(page, currentCard, name, "Type...", default, function(txt)
            Element.Value = txt
            if cb then task.spawn(function() pcall(cb, txt) end) end
        end)
        ConfigManager.Register(tabName .. "/" .. name, control)
        function Element:Set(val)
            Element.Value = val
            control.Set(val, false)
            if cb then task.spawn(function() pcall(cb, val) end) end
        end
        return Element
    end

    function Tab:CreateKeybind(options)
        options = options or {}
        local name = options.Name or "Keybind"
        local default = options.Default or Enum.KeyCode.E
        local cb = options.Callback
        local Element = { Value = default }
        local control = Keybind(page, currentCard, name, default, function(key)
            Element.Value = key
            if cb then task.spawn(function() pcall(cb, key) end) end
        end)
        ConfigManager.Register(tabName .. "/" .. name, control)
        function Element:Set(val)
            Element.Value = val
            control.Set(val, false)
            if cb then task.spawn(function() pcall(cb, val) end) end
        end
        return Element
    end

    function Tab:CreateColorpicker(options)
        options = options or {}
        local name = options.Name or "Colorpicker"
        local default = options.Default or Color3.fromRGB(255, 255, 255)
