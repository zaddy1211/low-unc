local function _godPlayCatchEffect(tool)
    if not catchEffect.Value then return end
    if not tool:IsA('Tool') or tool.Name ~= 'Football' then return end
    local character = player.Character
    local head = character and character:FindFirstChild('Head')
    if not head then return end
    local originPos = head.Position

    local style = tostring((catchEffectStyle and catchEffectStyle.Value) or 'Classic Burst')
    if style == 'Shockwave Ring' then
        _fxShockwave(originPos)
    elseif style == 'Firework' then
        _fxFirework(originPos)
    elseif style == 'Confetti' then
        _fxConfetti(originPos)
    elseif style == 'Rainbow Aura' then
        _fxRainbowAura(originPos)
    else
        _fxClassic(originPos)
    end
end
local function _godHookCatchEffect(character)
    for _, child in next, character:GetChildren() do
        if child:IsA('Tool') then _godPlayCatchEffect(child) end
    end
    character.ChildAdded:Connect(function(child)
        if child:IsA('Tool') then _godPlayCatchEffect(child) end
    end)
end
