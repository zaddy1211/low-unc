local function LoadMiscTab()
    local MiscTab = Window:CreateTab({ 
        Name = 'Misc', 
        Icon = 'rbxassetid://129082556946713' 
    })

    -- ═══════════════════════════════════════════════════════════════
    -- STATE & CONFIG MANAGER
    -- ═══════════════════════════════════════════════════════════════
    local State = {
        antiAdmin = false,
        fakeGlobalTag = false,
        infiniteZoom = false,
    }

    local Config = {
        fpsCap = 240,
        globalNumber = '7',
        globalRole = 'QB',
    }

    -- ═══════════════════════════════════════════════════════════════
    -- FPS ENGINE
    -- ═══════════════════════════════════════════════════════════════
    local FPSEngine = {}

    function FPSEngine.Start()
        task.spawn(function()
            while true do
                task.wait()
                pcall(function()
                    -- MOBILE SAFE: skip setfpscap on touch devices (flagged)
                    if not game:GetService("UserInputService").TouchEnabled then
                        pcall(function() setfpscap(Config.fpsCap) end)
                    end
                end)
            end
        end)
    end

    -- ═══════════════════════════════════════════════════════════════
    -- ANTI-ADMIN ENGINE
    -- ═══════════════════════════════════════════════════════════════
    local AntiAdminEngine = {}

    function AntiAdminEngine.Scan()
        local playerGui = player:FindFirstChild("PlayerGui")
        if not playerGui then return end

        local miscText = playerGui:FindFirstChild("MiscText")
        if not miscText then return end

        local isVIP = miscText:FindFirstChild("IsVIP")
        if not isVIP then return end
        if isVIP.Visible == true then return end

        for _, admin in next, players:GetPlayers() do
            if admin == player then continue end

            local swagData = admin:FindFirstChild("SwagData")
            if not swagData then continue end

            local adminTag = swagData:FindFirstChild("Admin")
            if not adminTag then continue end

            if adminTag.Value ~= "" then
                player:Kick("[Cheeto Hub] Detected Admin\nName: " .. admin.Name .. "\nID: " .. admin.UserId)
            end
        end
    end

    function AntiAdminEngine.Start()
        task.spawn(function()
            while task.wait() do
                if not State.antiAdmin then continue end
                pcall(AntiAdminEngine.Scan)
            end
        end)
    end

    -- ═══════════════════════════════════════════════════════════════
    -- GLOBAL TAG ENGINE
    -- ═══════════════════════════════════════════════════════════════
    local GlobalTagEngine = {}

    function GlobalTagEngine.Setup()
        pcall(function()
            local textChatService = game:GetService('TextChatService')
            if textChatService.ChatVersion ~= Enum.ChatVersion.TextChatService then return end

            textChatService.OnIncomingMessage = function(message)
                if not State.fakeGlobalTag then return end
                if not message.TextSource then return end

                local sender = game:GetService('Players'):GetPlayerByUserId(message.TextSource.UserId)
                if sender ~= game:GetService('Players').LocalPlayer then return end

                local props = Instance.new('TextChatMessageProperties')
                props.PrefixText = '<font color=\'#550000\'>[#' .. Config.globalNumber .. '-' .. Config.globalRole .. '-G]</font> ' .. sender.DisplayName .. ':'
                return props
            end
        end)
    end

    -- ═══════════════════════════════════════════════════════════════
    -- INFINITE ZOOM ENGINE
    -- ═══════════════════════════════════════════════════════════════
    local ZoomEngine = {
        originalDistance = nil,
    }

    function ZoomEngine.Enable()
        if not ZoomEngine.originalDistance then
            ZoomEngine.originalDistance = game:GetService('Players').LocalPlayer.CameraMaxZoomDistance
        end
        game:GetService('Players').LocalPlayer.CameraMaxZoomDistance = math.max(game:GetService('Players').LocalPlayer.CameraMaxZoomDistance, 1000)
    end

    function ZoomEngine.Disable()
        if ZoomEngine.originalDistance then
            game:GetService('Players').LocalPlayer.CameraMaxZoomDistance = ZoomEngine.originalDistance
        end
    end

    function ZoomEngine.Start()
        task.spawn(function()
            while true do
                task.wait(0.5)
                if not State.infiniteZoom then continue end
                ZoomEngine.Enable()
            end
        end)
    end

    -- ═══════════════════════════════════════════════════════════════
    -- INITIALIZE ENGINES
    -- ═══════════════════════════════════════════════════════════════
    FPSEngine.Start()
    AntiAdminEngine.Start()
    GlobalTagEngine.Setup()
    ZoomEngine.Start()

    -- ═══════════════════════════════════════════════════════════════
    -- UI BINDINGS
    -- ═══════════════════════════════════════════════════════════════
    fpsCap = MiscTab:CreateSlider({
        Name = 'Uncap FPS Amount',
        Min = 30,
        Max = 240,
        Default = 240,
        Increment = 1,
        Suffix = '',
        Tip = 'Sets the maximum FPS limit.',
        Callback = function(v) Config.fpsCap = v end,
    })

    antiAdmin = MiscTab:CreateToggle({
        Name = 'Anti Admin',
        Default = false,
        Tip = 'Automatically reacts when administrators are detected.',
        Keybind = nil,
        Callback = function(v) State.antiAdmin = v end,
    })

    local fakeGlobalTag = MiscTab:CreateToggle({
        Name = 'Enable Global Tag',
        Default = false,
        Tip = 'Adds a fake global chat tag to your messages.',
        Callback = function(v) State.fakeGlobalTag = v end,
    })

    MiscTab:CreateTextbox({
        Name = 'Global Number',
        Default = '7',
        Placeholder = 'Tag number...',
        MaxLength = 8,
        Tip = 'Number shown in the fake global tag.',
        Callback = function(v) Config.globalNumber = tostring(v or '7') end,
    })

    MiscTab:CreateTextbox({
        Name = 'Global Role',
        Default = 'QB',
        Placeholder = 'Role...',
        MaxLength = 16,
        Tip = 'Role shown in the fake global tag.',
        Callback = function(v) Config.globalRole = tostring(v or 'QB') end,
    })

    infiniteZoom = MiscTab:CreateToggle({
        Name = 'Infinite Zoom',
        Default = false,
        Tip = 'Raises camera max zoom distance while enabled.',
        Callback = function(v)
            State.infiniteZoom = v
            if v then
                ZoomEngine.Enable()
            else
                ZoomEngine.Disable()
            end
        end,
    })


end


