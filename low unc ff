    task.delay(Duration, function()
        local outTween = TweenService:Create(NotifCard, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Position = UDim2.new(1, 300, 0, 0),
            GroupTransparency = 1
        })
        outTween:Play()
        outTween.Completed:Wait()
        TweenService:Create(Wrapper, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Size = UDim2.new(0, 260, 0, 0)}):Play()
        task.delay(0.3, function() Wrapper:Destroy() end)
    end)
end

LyraLib.CreateWindow = function(self, options)
    local WindowTitle = options.Title or 'na'
    local TitlePrefix = options.Prefix or 'Lyra'
    local defaultTheme = options.Theme or 'Minimal Light'
    
    local ScreenGui = createInstance('ScreenGui', {
        Name = 'LyraUI',
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        Parent = uiParent
    })
    
    if uiParent:FindFirstChild('LyraUI') and uiParent:FindFirstChild('LyraUI') ~= ScreenGui then
        uiParent:FindFirstChild('LyraUI'):Destroy()
    end

    local isMobile = UserInputService.TouchEnabled or ((workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize.X or 9999) < 700)

    local GetViewportSize = function()
        local cam = workspace.CurrentCamera
        if cam then return cam.ViewportSize end
        return Vector2.new(1280, 720)
    end

    local GetResponsiveWindowSize = function()
        local view = GetViewportSize()
        if isMobile then
            local marginX = view.X <= 380 and 12 or 20
            local reservedTop = 54
            local winW = math.clamp(view.X - (marginX * 2), 330, 820)
            local winH = math.clamp(view.Y - reservedTop - 12, 390, 620)
            if view.X > view.Y then
                winH = math.clamp(view.Y - 34, 320, 440)
            end
            return winW, winH
        end
        return 820, 560
    end

    local WindowWidth, WindowHeight = GetResponsiveWindowSize()
    local TopbarHeight = isMobile and 92 or 60

