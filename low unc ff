container.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
        draggingHUD = true
        hudMoved = false
        hudDragStart = input.Position
        hudStartPosition = container.Position
    end
end)

container.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch then
        hudDragInput = input
    end
end)

userInputService.InputChanged:Connect(function(input)
    if draggingHUD and input == hudDragInput and hudDragStart and hudStartPosition then
        local delta = input.Position - hudDragStart
        if delta.Magnitude >= 6 then
            hudMoved = true
            hudWasDragged = true
        end
        if hudMoved then
            local vp = camera.ViewportSize
            local scaledWidth = container.AbsoluteSize.X
            local scaledHeight = container.AbsoluteSize.Y
            local centerX = math.clamp(
                (vp.X * hudStartPosition.X.Scale) + hudStartPosition.X.Offset + delta.X,
                scaledWidth / 2,
                vp.X - (scaledWidth / 2)
            )
            local topY = math.clamp(
                (vp.Y * hudStartPosition.Y.Scale) + hudStartPosition.Y.Offset + delta.Y,
                4,
                math.max(4, vp.Y - scaledHeight - 4)
            )
            container.Position = UDim2.fromOffset(centerX, topY)
        end
    end
end)

userInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
        draggingHUD = false
