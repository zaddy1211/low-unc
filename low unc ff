    -- ═══════════════════════════════════════════════════════════════
    -- STATE MANAGER
    -- ═══════════════════════════════════════════════════════════════
    local State = {
        autoRush = { Value = false },
        walkToLine = { Value = false },
        visualizeRushing = { Value = false },
        autoCatch = { Value = false },
        autoSwat = { Value = false },
        autoReflexJump = { Value = false },
        autoVoteSkip = { Value = false },
        autoFreeze = { Value = false },
        freezeOnCatch = { Value = false },
        autoQb = { Value = false },
        autoBoost = { Value = false },
        targetClosestPlayer = { Value = false },
        reflexGroundCheck = { Value = false },
    }

    local Config = {
        autoRushReactionTime = 0.15,
        autoCatchRadius = 0,
        autoCatchDelay = 0,
        autoSwatRadius = 0,
        autoSwatDelay = 0,
        autoReflexJumpRadius = 0,
        freezeDuration = 0,
        autoQbActivationDelay = 0,
        autoQbMethod = 'Walk',
        boostStrength = 1.5,
        boostRadius = 0,
        boostPower = 50,
    }

    -- ═══════════════════════════════════════════════════════════════
    -- DRAWING ENGINE — RUSH VISUALIZATION
    -- ═══════════════════════════════════════════════════════════════
    local RushVisuals = {}
    do
        local _drawPool = {}
        local _drawMeta = {
            Line = { Thickness = 2.5, ZIndex = 5 },
            Circle = { Thickness = 2, ZIndex = 5, NumSides = 36, Radius = 9, Filled = false },
            Triangle = { Thickness = 1, ZIndex = 5, Filled = true },
        }

        local function _acquireDraw(kind, colorKey, thickness)
            local cached = _drawPool[kind]
            if cached and #cached > 0 then
                local obj = table.remove(cached)
                obj.Visible = false
                obj.Transparency = 1
                return obj
            end

            local ok, obj = pcall(function()
                if game:GetService("UserInputService").TouchEnabled then return nil end
                local okD, resD = pcall(function() return Drawing and Drawing.new and Drawing.new(kind) end)
                if not okD then return nil end
                return resD
            end)

            if not (ok and obj) then return nil end

            local meta = _drawMeta[kind]
            obj.Color = (Theme and Theme[colorKey]) or (Theme and Theme.Accent) or Color3.fromRGB(255, 255, 255)
            obj.Thickness = thickness or meta.Thickness
            obj.Transparency = 1
            obj.Visible = false
            obj.ZIndex = meta.ZIndex

            if kind == "Circle" then
                obj.NumSides = meta.NumSides
                obj.Radius = meta.Radius
                obj.Filled = meta.Filled
            elseif kind == "Triangle" then
                obj.Filled = meta.Filled
            end

            return obj
        end

        local function _releaseDraw(kind, obj)
            if not obj then return end
            obj.Visible = false
            _drawPool[kind] = _drawPool[kind] or {}
            table.insert(_drawPool[kind], obj)
        end

        RushVisuals._pool = _drawPool
        RushVisuals._acquire = _acquireDraw
        RushVisuals._release = _releaseDraw

        RushVisuals.elements = {
            line = _acquireDraw("Line", "Accent", 2.5),
            circle = _acquireDraw("Circle", "Accent", 2),
            arrow = _acquireDraw("Triangle", "Accent", 1),
            holderLine = _acquireDraw("Line", "Accent2", 2),
            holderArrow = _acquireDraw("Triangle", "Accent2", 1),
            moveLine = _acquireDraw("Line", "Accent3", 2),
            moveArrow = _acquireDraw("Triangle", "Accent3", 1),
        }

        function RushVisuals:OrientArrow(tri, tip, dir, size)
            if not tri then return end
            local len = dir.Magnitude
            if len <= 0.0001 then
                tri.Visible = false
                return
            end
            local d = dir / len
            local perp = Vector2.new(-d.Y, d.X)
            local base = tip - d * size
            tri.PointA = tip
            tri.PointB = base + perp * (size * 0.55)
            tri.PointC = base - perp * (size * 0.55)
            tri.Visible = true
        end

        function RushVisuals:HideAll()
            for _, d in pairs(self.elements) do
                if d then
                    pcall(function() d.Visible = false end)
                end
            end
        end

        function RushVisuals:UpdateTheme()
            local function _safeColor(elem, key)
                if elem then elem.Color = (Theme and Theme[key]) or (Theme and Theme.Accent) or Color3.fromRGB(255, 255, 255) end
            end
            _safeColor(self.elements.line, "Accent")
            _safeColor(self.elements.circle, "Accent")
            _safeColor(self.elements.arrow, "Accent")
            _safeColor(self.elements.holderLine, "Accent2")
            _safeColor(self.elements.holderArrow, "Accent2")
            _safeColor(self.elements.moveLine, "Accent3")
            _safeColor(self.elements.moveArrow, "Accent3")
        end
    end

