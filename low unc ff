    -- ═══════════════════════════════════════════════════════════════
    -- AUTO BOOST — AERIAL INTERCEPT ENGINE
    -- ═══════════════════════════════════════════════════════════════
    local BoostEngine = {
        activeTween = nil,
    }

    task.spawn(function()
        while true do
            task.wait()

            if not State.autoBoost.Value then
                if BoostEngine.activeTween then
                    BoostEngine.activeTween:Cancel()
                    BoostEngine.activeTween = nil
                end
                continue
            end

            local char = player.Character
            if not char then continue end

            local hum = char:FindFirstChildOfClass('Humanoid')
            local hrp = char:FindFirstChild('HumanoidRootPart')
            local myHead = char:FindFirstChild('Head')
            if not (hum and hrp and myHead) then continue end

            if hum:GetState() == Enum.HumanoidStateType.Landed then
                if BoostEngine.activeTween then
                    BoostEngine.activeTween:Cancel()
                    BoostEngine.activeTween = nil
                end
                continue
            end

            local targetPlayer = nil

            if State.targetClosestPlayer.Value then
                local nearestBall, nearestBallDist = BallFinder.GetClosestBall(myHead.Position)
                if not nearestBall then continue end

                local closestDist = math.huge
                for _, v in next, players:GetPlayers() do
                    if v == player then continue end
                    local eChar = v.Character
                    if not eChar then continue end
                    local eHead = eChar:FindFirstChild('Head')
                    if not eHead then continue end
                    local dist = (eHead.Position - nearestBall.Position).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        targetPlayer = v
                    end
                end
            else
                local closestDist = math.huge
                for _, v in next, players:GetPlayers() do
                    if v == player then continue end
                    local eChar = v.Character
                    if not eChar then continue end
                    local eHead = eChar:FindFirstChild('Head')
                    if not eHead then continue end
                    local dist = (eHead.Position - myHead.Position).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        targetPlayer = v
                    end
                end
            end

            if not targetPlayer then continue end

            local eChar = targetPlayer.Character
            if not eChar then continue end

            local eHead = eChar:FindFirstChild('Head')
            local eHum = eChar:FindFirstChildOfClass('Humanoid')
            if not (eHead and eHum) then continue end

            local myState = hum:GetState()
            local eState = eHum:GetState()
            local distance = (eHead.Position - myHead.Position).Magnitude

            if distance > Config.boostRadius then continue end
            if myState ~= Enum.HumanoidStateType.Jumping and myState ~= Enum.HumanoidStateType.Freefall then continue end
            if eState ~= Enum.HumanoidStateType.Jumping and eState ~= Enum.HumanoidStateType.Freefall then continue end

            local speed = math.max(hum.WalkSpeed * Config.boostStrength, 1)
            local targetPos = eHead.Position
            local duration = math.max((hrp.Position - targetPos).Magnitude / speed, 0.01)

            if BoostEngine.activeTween then
                BoostEngine.activeTween:Cancel()
            end

            BoostEngine.activeTween = tweenService:Create(
                hrp,
                TweenInfo.new(duration, Enum.EasingStyle.Linear),
                { CFrame = CFrame.new(targetPos) }
            )

            BoostEngine.activeTween:Play()

            BoostEngine.activeTween.Completed:Once(function(state)
                if state ~= Enum.PlaybackState.Completed then return end
                hrp.AssemblyLinearVelocity = Vector3.new(
                    hrp.AssemblyLinearVelocity.X,
                    Config.boostPower,
                    hrp.AssemblyLinearVelocity.Z
                )
            end)
        end
    end)

