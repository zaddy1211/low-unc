                pcall(function()
                    firetouchinterest(catchPart, ball, 0)
                    firetouchinterest(catchPart, ball, 1)
                end)
            elseif v2BodyPosition and v2Ball == ball then
                v2BodyPosition:Destroy()
                v2BodyPosition, v2Ball = nil, nil
            end
        elseif v2BodyPosition then
            v2BodyPosition:Destroy()
            v2BodyPosition, v2Ball = nil, nil
        end

        for _, v in next, character:GetChildren() do
            if not v:IsA('BasePart') then continue end
            if not v.Name:lower():find('catch') then continue end

            local distance = (ball.Position - v.Position).Magnitude

