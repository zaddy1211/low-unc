local function FFWrapControl(control, initial, onSet)
    local Element = { Value = initial }
    function Element:Set(val)
        Element.Value = val
        if control and control.Set then
            control.Set(val, false)
        end
        if onSet then task.spawn(function() pcall(onSet, val) end) end
    end
    function Element:GetValue()
        if control and control.Get then return control.Get() end
        return Element.Value
    end
    Element.GetValue = function() return Element:GetValue() end
    return Element
end

local function CreateFFTab(tabName)
    if not pages[tabName] then CreatePage(tabName) end
    local page = pages[tabName]
    local sectionCount = 0
    local function ensureSection(title)
        sectionCount = sectionCount + 1
        return Section(page, title or tabName, nil)
    end
    local currentCard = ensureSection(tabName)

    local Tab = { Name = tabName, Page = page.Scroll }

    function Tab:CreateDivider()
        Divider(page, currentCard)
    end

    function Tab:CreateToggle(options)
        options = options or {}
        local name = options.Name or "Toggle"
        local default = options.Default == true
        local cb = options.Callback
        local Element = { Value = default }
        local control = Toggle(page, currentCard, name, default, function(state)
            Element.Value = state
            if cb then task.spawn(function() pcall(cb, state) end) end
        end)
        ConfigManager.Register(tabName .. "/" .. name, control)
        function Element:Set(val)
            Element.Value = val == true
            control.Set(Element.Value, false)
            if cb then task.spawn(function() pcall(cb, Element.Value) end) end
        end
        return Element
    end

    function Tab:CreateSlider(options)
        options = options or {}
        local name = options.Name or "Slider"
        local min = options.Min or 0
        local max = options.Max or 100
        local default = options.Default or min
        local suffix = options.Suffix or ""
        local cb = options.Callback
        local Element = { Value = default }
        local control = Slider(page, currentCard, name, min, max, default, suffix, function(v)
            Element.Value = v
            if cb then task.spawn(function() pcall(cb, v) end) end
        end)
        ConfigManager.Register(tabName .. "/" .. name, control)
        function Element:Set(val)
            Element.Value = val
            control.Set(val, false)
            if cb then task.spawn(function() pcall(cb, val) end) end
        end
        function Element:GetValue() return Element.Value end
        Element.GetValue = function() return Element.Value end
        return Element
    end

    function Tab:CreateDropdown(options)
        options = options or {}
        local name = options.Name or "Dropdown"
        local opts = options.Options or {}
        local default = options.Default
        if default == nil then default = opts[1] end
        local cb = options.Callback
        local Element = { Value = default }
