local selectedRange = function()
	local range = tonumber(magnetsRadius.Value) or 0
	local mode = tostring(magsType.Value or 'Custom'):lower()

	if mode == 'legit' then
		return range / 2
	elseif mode == 'league' then
		return range / 1.4
	elseif mode == 'blatant' then
		return range * 1.5
	end

	return range
end

local v2BodyPosition = nil
local v2Ball = nil

task.spawn(function()
    while true do
        task.wait()

        local character = player.Character
        if not character then continue end

        local humanoid = character:FindFirstChildOfClass('Humanoid')
        if not humanoid then continue end

        local ball = findClosestBall()
        if not ball then continue end

        local range = selectedRange()

        part.Size = Vector3.new(range, range, range)
        part.CFrame = CFrame.new(ball.Position)
        part.Parent = (footballMagnets.Value and showCatchHitbox.Value) and workspace.Terrain or nil

        if partRainbow then
            partRainbow.Size = Vector3.new(range + 1.2, range + 1.2, range + 1.2)
            partRainbow.CFrame = CFrame.new(ball.Position)
            partRainbow.Parent = (footballMagnets.Value and showRainbowHitbox.Value) and workspace.Terrain or nil
        end

        if footballMagnets.Value and magnetsV2.Value then
            local catchRight = character:FindFirstChild('CatchRight')
            local catchLeft = character:FindFirstChild('CatchLeft')
            local catchPart = catchRight or catchLeft
            if catchPart and (ball.Position - catchPart.Position).Magnitude <= range then
                if v2Ball ~= ball then
                    if v2BodyPosition then v2BodyPosition:Destroy() end
                    v2BodyPosition = Instance.new('BodyPosition')
                    v2BodyPosition.Name = 'MagnetsV2Force'
                    v2BodyPosition.MaxForce = Vector3.new(4000, 4000, 4000)
                    v2BodyPosition.P = 1000
                    v2BodyPosition.Parent = ball
                    v2Ball = ball
                end
                local away = catchPart.Position - ball.Position
                v2BodyPosition.Position = catchPart.Position + (away.Magnitude > 0 and away.Unit * 3 or Vector3.zero)
                pcall(function()
                    firetouchinterest(catchPart, ball, 0)
                    firetouchinterest(catchPart, ball, 1)
                end)
            elseif v2BodyPosition and v2Ball == ball then
                v2BodyPosition:Destroy()
                v2BodyPosition, v2Ball = nil, nil
            end
        elseif v2BodyPosition then
            v2BodyPosition:Destroy()
            v2BodyPosition, v2Ball = nil, nil
