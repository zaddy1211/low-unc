            if not targetRoot then continue end

            local football = targetRoot.Parent:FindFirstChild('Football')
            if not football then continue end

            local footballPart = football:FindFirstChildWhichIsA('BasePart')
            if not footballPart then continue end

            local interceptPos = Predictor.GetInterceptPosition(targetRoot, targetHum, Config.autoRushReactionTime)
            humanoid:MoveTo(interceptPos)
        end
    end)

