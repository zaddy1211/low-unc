local function LoadPlayerTab()
    local PlayerTab = Window:CreateTab({ 
        Name = 'Player', 
        Icon = 'rbxassetid://103807548355126' 
    })

    -- ═══════════════════════════════════════════════════════════════
    -- STATE & CONFIG MANAGER
    -- ═══════════════════════════════════════════════════════════════
    local State = {
        customWalkSpeed = false,
        customJumpPower = false,
        angleEnhancer = false,
        angleEnhancerIndicator = false,
        autoFlip = false,
        enableFly = false,
        customDiveBoost = false,
    }

    local Config = {
        walkSpeedValue = 25,
        walkSpeedType = 'Normal',
        jumpPowerValue = 50,
        angleEnhanceBoost = 50,
        flySpeed = 50,
        diveBoostPower = 5,
        diveAssistRadius = 0,
    }

    -- ═══════════════════════════════════════════════════════════════
    -- WALKSPEED ENGINE
    -- ═══════════════════════════════════════════════════════════════
    local WalkSpeedEngine = {}

    function WalkSpeedEngine.Process()
        local char = player.Character
        if not char then return end

        local humanoid = char:FindFirstChildOfClass('Humanoid')
        if not humanoid then return end
        if humanoid.PlatformStand then return end
        if humanoid.WalkSpeed == 0 then return end

        local root = char:FindFirstChild('HumanoidRootPart')
        if not root then return end

        local direction = Vector3.new(humanoid.MoveDirection.X, 0, humanoid.MoveDirection.Z)
        if direction.Magnitude <= 0 then return end

        local velocity = direction.Unit * (Config.walkSpeedType == 'CFrame' and (Config.walkSpeedValue / 75) or Config.walkSpeedValue)

        -- Adjust animation speed
        if humanoid:GetState() == Enum.HumanoidStateType.Running then
            local scale = Config.walkSpeedValue / math.max(humanoid.WalkSpeed, 1)
            local animator = humanoid:FindFirstChildOfClass('Animator')
            if animator then
                for _, track in next, animator:GetPlayingAnimationTracks() do
                    track:AdjustSpeed(scale)
                end
            end
        end

        -- Apply velocity
        if Config.walkSpeedType ~= 'CFrame' then
            root.AssemblyLinearVelocity = Vector3.new(velocity.X, root.AssemblyLinearVelocity.Y, velocity.Z)
        else
            root.CFrame = root.CFrame + velocity
        end
    end

    function WalkSpeedEngine.Start()
        task.spawn(function()
            while true do
                task.wait()
                if not State.customWalkSpeed then continue end
                pcall(WalkSpeedEngine.Process)
            end
        end)
    end

    -- ═══════════════════════════════════════════════════════════════
    -- JUMPPOWER ENGINE
    -- ═══════════════════════════════════════════════════════════════
    local JumpPowerEngine = {}

    function JumpPowerEngine.Process()
        local char = player.Character
        if not char then return end

        local humanoid = char:FindFirstChildOfClass('Humanoid')
        if not humanoid then return end

        local root = char:FindFirstChild('HumanoidRootPart')
        if not root then return end

        if humanoid:GetState() ~= Enum.HumanoidStateType.Jumping then return end

        task.wait()
        root.AssemblyLinearVelocity = Vector3.new(
            root.AssemblyLinearVelocity.X, 
            Config.jumpPowerValue, 
            root.AssemblyLinearVelocity.Z
        )
    end

    function JumpPowerEngine.Start()
        task.spawn(function()
            while true do
                task.wait()
                if not State.customJumpPower then continue end
                pcall(JumpPowerEngine.Process)
            end
        end)
    end

    -- ═══════════════════════════════════════════════════════════════
    -- ANGLE ENHANCER ENGINE
    -- ═══════════════════════════════════════════════════════════════
    local AngleEnhancerEngine = {
        lastTick = 0,
        oldLookVector = nil,
        lastIndicatorToast = 0,
    }

    function AngleEnhancerEngine.Process()
        local char = player.Character
        if not char then
            AngleEnhancerEngine.oldLookVector = nil
            return
        end

        local humanoid = char:FindFirstChildOfClass('Humanoid')
        local hrp = char:FindFirstChild('HumanoidRootPart')
        if not humanoid or not hrp then
            AngleEnhancerEngine.oldLookVector = nil
            return
        end

        if humanoid:GetState() ~= Enum.HumanoidStateType.Jumping then
            return
        end

        local currentTime = tick()
        local newLookVector = hrp.CFrame.LookVector

        if not AngleEnhancerEngine.oldLookVector then
            AngleEnhancerEngine.oldLookVector = newLookVector
            AngleEnhancerEngine.lastTick = currentTime
            return
        end

        local angleChange = math.acos(math.clamp(AngleEnhancerEngine.oldLookVector:Dot(newLookVector), -1, 1))

        -- Update tracking
        if currentTime - AngleEnhancerEngine.lastTick >= 0.2 and angleChange > math.rad(5) then
            AngleEnhancerEngine.lastTick = currentTime
            AngleEnhancerEngine.oldLookVector = newLookVector
        end

        -- Apply boost
        if angleChange > math.rad(25) and currentTime - AngleEnhancerEngine.lastTick <= 2.5 then
            AngleEnhancerEngine.lastTick = currentTime
            AngleEnhancerEngine.oldLookVector = newLookVector

            task.wait()
            local vel = hrp.AssemblyLinearVelocity
            hrp.AssemblyLinearVelocity = Vector3.new(vel.X, Config.angleEnhanceBoost, vel.Z)

            -- Indicator
            if State.angleEnhancerIndicator then
                local now = tick()
                if now - AngleEnhancerEngine.lastIndicatorToast >= 1.5 then
                    AngleEnhancerEngine.lastIndicatorToast = now
                    pcall(function()
                        notify("Angle Enhancer", "Angle boost applied!", 2.5)
                    end)
                end
            end
        end
    end

    function AngleEnhancerEngine.Start()
        task.spawn(function()
            while true do
                task.wait()
                if not State.angleEnhancer then
                    AngleEnhancerEngine.oldLookVector = nil
                    continue
                end
                pcall(AngleEnhancerEngine.Process)
            end
        end)
    end

    -- ═══════════════════════════════════════════════════════════════
    -- AUTO FLIP ENGINE
    -- ═══════════════════════════════════════════════════════════════
    local AutoFlipEngine = {
        runtime = 0,
        jumptime = 0,
        hittime = 0,
        armed = false,
        velocityLine = nil,
        used = false,
        prevPlatformStand = false,
        sequence = 0,
        pack = nil,
    }

    function AutoFlipEngine.XZ(v)
        local f = Vector3.new(v.X, 0, v.Z)
        return f.Magnitude > 0.001 and f.Unit or nil
    end

    function AutoFlipEngine.Reset()
        if not AutoFlipEngine.pack then return end
        for _, obj in next, { AutoFlipEngine.pack.spin, AutoFlipEngine.pack.ra, AutoFlipEngine.pack.pivot, AutoFlipEngine.pack.ha } do
            if obj then pcall(function() obj:Destroy() end) end
        end
        AutoFlipEngine.pack = nil
    end

    function AutoFlipEngine.Flip(root, head)
        AutoFlipEngine.Reset()

        local mass = math.max(root.AssemblyMass, 1)

        local ha = Instance.new("Attachment")
        ha.Parent = head

        local pivot = Instance.new("AlignPosition")
        pivot.Mode = Enum.PositionAlignmentMode.OneAttachment
        pivot.Attachment0 = ha
        pivot.Position = head.Position + Vector3.new(0, 0.15, 0)
        pivot.MaxForce = 180000
        pivot.Responsiveness = 120
        pivot.RigidityEnabled = false
        pivot.ApplyAtCenterOfMass = false
        pivot.Parent = head

        local ra = Instance.new("Attachment")
        ra.Parent = root

        local spin = Instance.new("AngularVelocity")
        spin.Attachment0 = ra
        spin.RelativeTo = Enum.ActuatorRelativeTo.Attachment0
        spin.AngularVelocity = Vector3.new(-9, 0, 0)
        spin.MaxTorque = 50000
        spin.Parent = root

        root:ApplyAngularImpulse(root.CFrame.RightVector * (-16 * mass))

        AutoFlipEngine.pack = { ha = ha, pivot = pivot, ra = ra, spin = spin }
    end

    function AutoFlipEngine.Process()
        local char = player.Character
        if not char then
            AutoFlipEngine.Reset()
            AutoFlipEngine.armed, AutoFlipEngine.velocityLine, AutoFlipEngine.used, AutoFlipEngine.prevPlatformStand = false, nil, false, false
            return
        end

        local hum = char:FindFirstChildOfClass("Humanoid")
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local head = char:FindFirstChild("Head")

        if not hum or not hrp or not head then return end

        local now = tick()

        -- Track states
        if hum:GetState() == Enum.HumanoidStateType.Running then AutoFlipEngine.runtime = now end
        if hum:GetState() == Enum.HumanoidStateType.Jumping then AutoFlipEngine.jumptime = now end

        -- PlatformStand detection
        local ps = hum.PlatformStand
        if ps ~= AutoFlipEngine.prevPlatformStand then
            if ps then
                AutoFlipEngine.armed = (now - AutoFlipEngine.runtime <= 0.5) and (now - AutoFlipEngine.jumptime <= 0.7)
                AutoFlipEngine.velocityLine = AutoFlipEngine.XZ(hrp.AssemblyLinearVelocity) or AutoFlipEngine.XZ(hrp.CFrame.LookVector)
                AutoFlipEngine.used = false
            else
                AutoFlipEngine.armed, AutoFlipEngine.velocityLine, AutoFlipEngine.used = false, nil, false
                AutoFlipEngine.sequence += 1
                AutoFlipEngine.Reset()
            end
            AutoFlipEngine.prevPlatformStand = ps
        end

        if not ps or not AutoFlipEngine.armed or AutoFlipEngine.pack then return end

        -- Raycast for ground
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Exclude
        params.FilterDescendantsInstances = { char }

        local result = workspace:Raycast(head.Position, Vector3.new(0, -3, 0), params)
        if not result or not result.Instance then return end
        if AutoFlipEngine.used or (now - AutoFlipEngine.hittime < 0.12) then return end

        local dist = (head.Position - result.Position).Magnitude
        if dist > 1.6 then return end

        -- Check alignment
        local move = AutoFlipEngine.XZ(hrp.AssemblyLinearVelocity) or AutoFlipEngine.velocityLine
        local face = AutoFlipEngine.XZ(hrp.CFrame.LookVector)

        if not move or not face or face:Dot(move) < 0.78 then return end

        -- Execute flip
        AutoFlipEngine.hittime = now
        AutoFlipEngine.used = true
        AutoFlipEngine.sequence += 1
        local currentSeq = AutoFlipEngine.sequence

        AutoFlipEngine.Flip(hrp, head)

        task.delay(0.24, function()
            if currentSeq == AutoFlipEngine.sequence then
                AutoFlipEngine.Reset()
            end
        end)
    end

    function AutoFlipEngine.Start()
        task.spawn(function()
            while true do
                task.wait()
                if not State.autoFlip then
                    AutoFlipEngine.Reset()
                    AutoFlipEngine.armed, AutoFlipEngine.velocityLine, AutoFlipEngine.used, AutoFlipEngine.prevPlatformStand = false, nil, false, false
                    continue
                end
                pcall(AutoFlipEngine.Process)
            end
        end)
    end

    -- ═══════════════════════════════════════════════════════════════
    -- FLY ENGINE
    -- ═══════════════════════════════════════════════════════════════
    local FlyEngine = {
        gyro = nil,
        velocity = nil,
        connection = nil,
    }

    function FlyEngine.Start()
        local char = player.Character
        if not char then return end

        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        FlyEngine.Stop()

        FlyEngine.gyro = Instance.new("BodyGyro")
        FlyEngine.velocity = Instance.new("BodyVelocity")

        FlyEngine.gyro.P = 9e4
        FlyEngine.gyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
        FlyEngine.gyro.CFrame = hrp.CFrame

        FlyEngine.velocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        FlyEngine.velocity.Velocity = Vector3.zero

        FlyEngine.gyro.Parent = hrp
        FlyEngine.velocity.Parent = hrp

        FlyEngine.connection = runService.Heartbeat:Connect(function()
            if not State.enableFly or not hrp.Parent then return end

            local cam = workspace.CurrentCamera
            local look = cam.CFrame.LookVector
            local move = Vector3.zero

            if userInputService:IsKeyDown(Enum.KeyCode.W) then move = move + look end
            if userInputService:IsKeyDown(Enum.KeyCode.S) then move = move - look end
            if userInputService:IsKeyDown(Enum.KeyCode.D) then move = move + cam.CFrame.RightVector end
            if userInputService:IsKeyDown(Enum.KeyCode.A) then move = move - cam.CFrame.RightVector end
            if userInputService:IsKeyDown(Enum.KeyCode.E) then move = move + Vector3.new(0, 1, 0) end
            if userInputService:IsKeyDown(Enum.KeyCode.Q) then move = move - Vector3.new(0, 1, 0) end

            if move.Magnitude > 0 then
                move = move.Unit * Config.flySpeed
            end

            FlyEngine.velocity.Velocity = move
            FlyEngine.gyro.CFrame = cam.CFrame
        end)
    end

    function FlyEngine.Stop()
        if FlyEngine.connection then
            FlyEngine.connection:Disconnect()
            FlyEngine.connection = nil
        end
        if FlyEngine.gyro then
            pcall(function() FlyEngine.gyro:Destroy() end)
            FlyEngine.gyro = nil
        end
        if FlyEngine.velocity then
            pcall(function() FlyEngine.velocity:Destroy() end)
            FlyEngine.velocity = nil
        end
    end

    -- Auto-reconnect on respawn
    player.CharacterAdded:Connect(function()
        task.wait(0.5)
        if State.enableFly then
            FlyEngine.Start()
        end
    end)

    -- ═══════════════════════════════════════════════════════════════
    -- DIVE BOOST ENGINE
    -- ═══════════════════════════════════════════════════════════════
    local DiveBoostEngine = {
        connection = nil,
        busy = false,
    }

    function DiveBoostEngine.FindBallCarrier()
        local closestDist, carrier = math.huge, nil

        for _, plr in next, players:GetPlayers() do
            if plr == player or plr.Team == player.Team then continue end
            local char = plr.Character
            if not char or not char:FindFirstChildOfClass("Tool") then continue end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then continue end
            local dist = (hrp.Position - player.Character.HumanoidRootPart.Position).Magnitude
            if dist < closestDist then
                closestDist = dist
                carrier = plr
            end
        end

        return carrier, closestDist
    end

    function DiveBoostEngine.Process()
        if DiveBoostEngine.busy then return end
        DiveBoostEngine.busy = true

        pcall(function()
            task.wait(0.05)

            local char = player.Character
            if not char then return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hrp or not hum then return end

            -- Find target
            local ball = nil
            pcall(function() ball = findClosestBall() end)

            local targetPos = nil
            if ball then
                targetPos = ball.Position
            else
                local carrier = DiveBoostEngine.FindBallCarrier()
                if carrier and carrier.Character then
                    local carrierHRP = carrier.Character:FindFirstChild("HumanoidRootPart")
                    if carrierHRP then
                        targetPos = carrierHRP.Position
                    end
                end
            end

            -- Redirect velocity toward target
            if targetPos then
                local diff = targetPos - hrp.Position
                local dist = diff.Magnitude
                if Config.diveAssistRadius > 0 and dist <= Config.diveAssistRadius and dist > 0 then
                    local flatDiff = Vector3.new(diff.X, 0, diff.Z)
                    if flatDiff.Magnitude > 0 then
                        local vel = hrp.AssemblyLinearVelocity
                        local speed = vel.Magnitude
                        if speed > 0 then
                            hrp.AssemblyLinearVelocity = flatDiff.Unit * speed
                        end
                    end
                end
            end

            -- Apply boost
            hrp.AssemblyLinearVelocity = hrp.AssemblyLinearVelocity + (hum.MoveDirection * Config.diveBoostPower)
        end)

        DiveBoostEngine.busy = false
    end

    function DiveBoostEngine.Start()
        task.spawn(function()
            while true do
                task.wait()
                if not State.customDiveBoost then
                    if DiveBoostEngine.connection then
                        DiveBoostEngine.connection:Disconnect()
                        DiveBoostEngine.connection = nil
                    end
                    continue
                end

                local char = player.Character
                if not char then
                    if DiveBoostEngine.connection then
                        DiveBoostEngine.connection:Disconnect()
                        DiveBoostEngine.connection = nil
                    end
                    continue
                end

                local hum = char:FindFirstChildOfClass("Humanoid")
                if not hum then continue end

                if DiveBoostEngine.connection then continue end

                DiveBoostEngine.connection = hum:GetPropertyChangedSignal("PlatformStand"):Connect(function()
                    if not State.customDiveBoost or not hum.PlatformStand then return end
                    DiveBoostEngine.Process()
                end)
            end
        end)
    end

    -- ═══════════════════════════════════════════════════════════════
    -- INITIALIZE ENGINES
