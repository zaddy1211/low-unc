local _rushColorOf = function(key)
    return (Theme and Theme[key]) or (Theme and Theme.Accent) or Color3.fromRGB(255, 255, 255)
end

local function _newRushDraw(kind, colorKey, thickness)
    local ok, obj = pcall(function()
        return Drawing and Drawing.new and Drawing.new(kind)
    end)
    if ok and obj then
        obj.Color = _rushColorOf(colorKey)
        obj.Thickness = thickness or 2
        obj.Transparency = 0
        obj.Visible = false
        obj.ZIndex = 5
        if kind == "Circle" then
            obj.NumSides = 36
            obj.Radius = 9
            obj.Filled = false
        elseif kind == "Triangle" then
            obj.Filled = true
        end
        return obj
    end
end

local function _ensureRushDraws()
    if _rushDraws.ready then return end
    _rushDraws.line = _newRushDraw("Line", "Accent", 2.5)
    _rushDraws.circle = _newRushDraw("Circle", "Accent", 2)
    _rushDraws.arrow = _newRushDraw("Triangle", "Accent", 1)
    _rushDraws.holderLine = _newRushDraw("Line", "Accent2", 2)
    _rushDraws.holderArrow = _newRushDraw("Triangle", "Accent2", 1)
    _rushDraws.moveLine = _newRushDraw("Line", "Accent3", 2)
    _rushDraws.moveArrow = _newRushDraw("Triangle", "Accent3", 1)
    _rushDraws.ready = true
end

local function _orientArrow(tri, tip, dir, size)
    if not tri then return end
    local len = dir.Magnitude
    if not (len > 0.0001) then
        tri.Visible = false
        return
    end
    local d = dir / len
    local px = Vector2.new(-d.Y, d.X)
    local base = tip - d * size
    tri.PointA = tip
    tri.PointB = base + px * (size * 0.55)
    tri.PointC = base - px * (size * 0.55)
    tri.Visible = true
end

local function _hideRushDraws()
    for key, d in pairs(_rushDraws) do
        if typeof(d) == "table" and d.Visible ~= nil then
            d.Visible = false
        end
    end
end

